{
  "ignoreCommand": "CHANGED=$(curl -sf \"https://api.github.com/repos/cesarortegaau-design/IventIA/commits/$VERCEL_GIT_COMMIT_SHA\" 2>/dev/null | grep '\"filename\"' | grep -E '\"apps/community/|packages/shared/|packages/prisma/'); [ -n \"$CHANGED\" ] && exit 1; exit 0",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.exposaantafe.com.mx/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
