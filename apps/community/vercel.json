{
  "ignoreCommand": "git diff --quiet $VERCEL_GIT_PREVIOUS_SHA $VERCEL_GIT_COMMIT_SHA -- apps/community/ packages/shared/ packages/prisma/",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.exposaantafe.com.mx/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

