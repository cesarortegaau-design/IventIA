{
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- apps/iflag/ packages/shared/ packages/prisma/",
  "framework": "vite",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://iventia-api.onrender.com/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
