{
  "name": "@iventia/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --external:@prisma/client --external:bcryptjs --external:bullmq --external:cors --external:dayjs --external:decimal.js --external:dotenv --external:express --external:express-rate-limit --external:helmet --external:ioredis --external:jsonwebtoken --external:morgan --external:multer --external:nodemailer --external:stripe --external:twilio --external:uuid --external:zod --external:prisma-generated --external:socket.io --external:pdfkit --outfile=dist/index.js",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@iventia/prisma": "workspace:*",
    "@iventia/shared": "workspace:*",
    "@prisma/client": "^5.13.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.20",
    "decimal.js": "^10.6.0",
    "docxtemplater": "^3.68.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "pdfkit": "^0.18.0",
    "pizzip": "^3.2.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "stripe": "^22.0.0",
    "twilio": "^4.18.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.0",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.25.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
