generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output        = "../../node_modules/prisma-generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ResourceType {
  CONSUMABLE
  EQUIPMENT
  SPACE
  FURNITURE
  SERVICE
  DISCOUNT
  TAX
  PERSONAL
  TICKET
}

enum DepartmentType {
  INTERNAL
  EXTERNAL
}

enum EventStatus {
  QUOTED
  CONFIRMED
  IN_EXECUTION
  CLOSED
  CANCELLED
}

enum EventPhase {
  SETUP
  EVENT
  TEARDOWN
}

enum OrderStatus {
  QUOTED
  CONFIRMED
  EXECUTED
  INVOICED
  CANCELLED
  CREDIT_NOTE
}

enum PaymentStatus {
  PENDING
  IN_PAYMENT
  PAID
  IN_REVIEW
}

enum PersonType {
  PHYSICAL
  MORAL
}

enum UserRole {
  ADMIN
  NORMAL
  READ_ONLY
}

enum PaymentMethod {
  CASH
  TRANSFER
  CREDIT_CARD
  CHECK
  SWIFT
}

enum PricingTier {
  EARLY
  NORMAL
  LATE
}

enum InteractionType {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  NOTE
}

enum TaskStatus {
  PENDING
  DONE
  CANCELLED
}

enum GameStatus {
  PENDING
  ATTENDANCE
  IN_PROGRESS
  HALFTIME
  FINISHED
}

enum GameEventType {
  TOUCHDOWN
  EXTRA_POINT
  SAFETY
  FLAG_PENALTY
  DOWN_UPDATE
  POSSESSION_CHANGE
  GAME_START
  GAME_END
  HALFTIME_START
  HALFTIME_END
  TIMER_START
  TIMER_STOP
  TIMEOUT
  SCORE_ADJUST
  INTERCEPTION
}

enum SenderType {
  ADMIN
  PORTAL_USER
}

enum SupplierType {
  DISTRIBUTOR
  MANUFACTURER
  WHOLESALER
  SERVICES
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum PurchaseOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  INVOICED
  CANCELLED
}

enum AvailabilityStatus {
  AVAILABLE
  BY_ORDER
  DISCONTINUED
  TEMPORARILY_OUT
}

enum ContractStatus {
  EN_FIRMA
  FIRMADO
  CANCELADO
}

enum StandStatus {
  AVAILABLE
  RESERVED
  SOLD
  BLOCKED
}

enum TemplateContext {
  EVENT
  ORDER
  CONTRACT
}

enum ArtCapitalUserRole {
  ARTIST
  COLLECTOR
  ADMIN
}

enum ArtCapitalOrderStatus {
  QUOTED
  CONFIRMED
  IN_PAYMENT
  PAID
  INVOICED
  CANCELLED
  CREDIT_NOTE
}

enum ArtCapitalProductStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ARCHIVED
}

enum ArtworkStatus {
  AVAILABLE
  SOLD
  RESERVED
  ARCHIVED
}

enum ArtMedium {
  OIL
  ACRYLIC
  WATERCOLOR
  SCULPTURE
  PHOTOGRAPHY
  PRINT
  DIGITAL
  MIXED_MEDIA
}

enum ArtStyle {
  IMPRESSIONISM
  SURREALISM
  POP_ART
  CUBISM
  ABSTRACT
  REALISM
  EXPRESSIONISM
  CONTEMPORARY
  TRADITIONAL
  MODERNISM
}

enum GalleryOrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ClassStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

// ─── Multi-tenancy ────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(200)
  slug      String   @unique @db.VarChar(100)
  settings  Json     @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users             User[]
  profiles          Profile[]
  departments       Department[]
  organizations     Organization[]
  resources         Resource[]
  priceLists        PriceList[]
  clients           Client[]
  events            Event[]
  orders            Order[]
  notifications     Notification[]
  interactions      ClientInteraction[]
  clientTasks       ClientTask[]
  portalUsers       PortalUser[]
  portalAccessCodes PortalAccessCode[]
  conversations     Conversation[]

  // Arte Capital
  artCapitalUsers           ArtCapitalUser[]
  artCapitalMembershipTiers ArtCapitalMembershipTier[]
  artCapitalProducts        ArtCapitalProduct[]
  artCapitalOrders          ArtCapitalOrder[]
  artCapitalMemberships     ArtCapitalMembership[]
  artCapitalTransactions    ArtCapitalTransaction[]

  // Gallery
  galleryArtworks         GalleryArtwork[]
  galleryArtists          GalleryArtist[]
  galleryCollections      GalleryCollection[]
  galleryLocations        GalleryLocation[]
  galleryMemberships      GalleryMembership[]
  galleryClasses          GalleryClass[]
  galleryClassEnrollments GalleryClassEnrollment[]
  galleryExhibitions      GalleryExhibition[]
  galleryCarts            GalleryCart[]
  galleryCartItems        GalleryCartItem[]
  galleryOrders           GalleryOrder[]
  galleryOrderLineItems   GalleryOrderLineItem[]
  galleryFavorites        GalleryFavorite[]

  // Contracts
  contracts         Contract[]
  documentTemplates DocumentTemplate[]

  // Purchase Order Module
  suppliers             Supplier[]
  supplierPriceLists    SupplierPriceList[]
  purchaseOrders        PurchaseOrder[]
  warehouses            Warehouse[]
  resourceInventory     ResourceInventory[]
  inventoryMovements    InventoryMovement[]
  supplierPortalUsers   SupplierPortalUser[]
  supplierPortalCodes   SupplierPortalCode[]
  supplierConversations SupplierConversation[]
  supplierDocuments     SupplierDocument[]

  // Client Relations
  clientRelations ClientRelation[]

  // I-Flag
  footballGames FootballGame[]
  gameEvents    GameEvent[]

  // Ticket System
  ticketEvents  TicketEvent[]
  ticketOrders  TicketOrder[]

  @@map("tenants")
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model Profile {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant     Tenant             @relation(fields: [tenantId], references: [id])
  privileges ProfilePrivilege[]
  users      User[]

  @@unique([tenantId, name])
  @@map("profiles")
}

model ProfilePrivilege {
  id           String @id @default(uuid())
  profileId    String @map("profile_id")
  privilegeKey String @map("privilege_key") @db.VarChar(100)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, privilegeKey])
  @@map("profile_privileges")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  email        String   @unique @db.VarChar(200)
  passwordHash String?  @map("password_hash")
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  phone        String?  @db.VarChar(30)
  role         UserRole @default(NORMAL)
  profileId    String?  @map("profile_id")
  isActive     Boolean  @default(true) @map("is_active")
  azureAdId    String?  @map("azure_ad_id") @db.VarChar(200)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant              Tenant                       @relation(fields: [tenantId], references: [id])
  profile             Profile?                     @relation(fields: [profileId], references: [id])
  userDepartments     UserDepartment[]
  privileges          UserPrivilege[]
  createdEvents       Event[]                      @relation("EventCreatedBy")
  createdOrders       Order[]                      @relation("OrderCreatedBy")
  assignedOrders      Order[]                      @relation("OrderAssignedTo")
  recordedPayments    OrderPayment[]
  uploadedDocuments   OrderDocument[]
  statusHistory       OrderStatusHistory[]
  auditLogs           AuditLog[]
  createdInteractions ClientInteraction[]          @relation("InteractionCreator")
  assignedTasks       ClientTask[]                 @relation("TaskAssignee")
  createdTasks        ClientTask[]                 @relation("TaskCreator")
  createdPortalCodes  PortalAccessCode[]           @relation("PortalCodeCreator")
  createdSuppliers    Supplier[]
  poCreatedBy         PurchaseOrder[]              @relation("POCreatedBy")
  poConfirmedBy       PurchaseOrder[]              @relation("POConfirmedBy")
  poStatusHistory     PurchaseOrderStatusHistory[]
  poDocuments         PurchaseOrderDocument[]
  managedWarehouses   Warehouse[]
  inventoryMovements  InventoryMovement[]
  createdContracts    Contract[]           @relation("ContractCreatedBy")
  contractPayments    ContractPayment[]
  createdTemplates    DocumentTemplate[]   @relation("TemplateCreatedBy")
  footballGames       FootballGame[]
  gameEvents          GameEvent[]

  @@index([tenantId, isActive])
  @@map("users")
}

model UserDepartment {
  userId       String @map("user_id")
  departmentId String @map("department_id")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([userId, departmentId])
  @@map("user_departments")
}

model UserPrivilege {
  id           String  @id @default(uuid())
  userId       String  @map("user_id")
  privilegeKey String  @map("privilege_key") @db.VarChar(100)
  granted      Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, privilegeKey])
  @@map("user_privileges")
}

// ─── Departments ──────────────────────────────────────────────────────────────

model Organization {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  clave             String   @db.VarChar(50)
  descripcion       String   @db.VarChar(300)
  datosFiscales     Json     @default("{}") @map("datos_fiscales")
  datosDemograficos Json     @default("{}") @map("datos_demograficos")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant              Tenant                @relation(fields: [tenantId], references: [id])
  departmentOrgs      DepartmentOrganization[]
  orders              Order[]
  purchaseOrders      PurchaseOrder[]

  @@unique([tenantId, clave])
  @@index([tenantId, isActive])
  @@map("organizations")
}

model DepartmentOrganization {
  departmentId   String @map("department_id")
  organizationId String @map("organization_id")

  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([departmentId, organizationId])
  @@map("department_organizations")
}

model Department {
  id        String         @id @default(uuid())
  tenantId  String         @map("tenant_id")
  name      String         @db.VarChar(200)
  type      DepartmentType @default(INTERNAL)
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  tenant          Tenant                   @relation(fields: [tenantId], references: [id])
  userDepartments UserDepartment[]
  resources       Resource[]
  departmentOrgs  DepartmentOrganization[]

  @@index([tenantId, isActive])
  @@map("departments")
}

// ─── Resources (Products & Services) ─────────────────────────────────────────

model Resource {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  code           String       @db.VarChar(50)
  name           String       @db.VarChar(200)
  type           ResourceType
  description    String?      @db.Text
  unit           String?      @db.VarChar(50)
  stock          Int          @default(0)
  stockLocation  String?      @map("stock_location") @db.VarChar(200)
  checkStock     Boolean      @default(false) @map("check_stock")
  checkDuplicate Boolean      @default(true) @map("check_duplicate")
  recoveryTime   Int          @default(0) @map("recovery_time")
  areaSqm        Decimal?     @map("area_sqm") @db.Decimal(10, 2)
  capacity       Int?
  departmentId   String?      @map("department_id")
  portalVisible  Boolean      @default(false) @map("portal_visible")
  portalDesc     String?      @map("portal_desc") @db.Text
  portalBlobKey  String?      @map("portal_blob_key") @db.VarChar(500)
  imageMain      String?      @map("image_main") @db.VarChar(500)
  imageDesc      String?      @map("image_desc") @db.VarChar(500)
  imageExtra     String?      @map("image_extra") @db.VarChar(500)
  isPackage      Boolean      @default(false) @map("is_package")
  isSubstitute   Boolean      @default(false) @map("is_substitute")
  factor         Decimal      @default(1) @db.Decimal(10, 2)

  isActive  Boolean  @default(true) @map("is_active")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant             Tenant                  @relation(fields: [tenantId], references: [id])
  department         Department?             @relation(fields: [departmentId], references: [id])
  priceListItems     PriceListItem[]
  eventSpaces        EventSpace[]
  orderLineItems     OrderLineItem[]
  packageComponents  PackageComponent[]      @relation("PackageChildren")
  parentPackages     PackageComponent[]      @relation("PackageParents")
  supplierPriceItems SupplierPriceListItem[] @relation("SupplierPriceListItems")
  purchaseOrderItems PurchaseOrderLineItem[] @relation("PurchaseOrderLineItems")
  inventory          ResourceInventory[]
  movements          InventoryMovement[]
  ticketSections     TicketSection[]

  @@unique([tenantId, code])
  @@index([tenantId, type, isActive])
  @@index([tenantId, isPackage])
  @@map("resources")
}

// ─── Package Components ───────────────────────────────────────────────────────

model PackageComponent {
  id                  String @id @default(uuid())
  packageResourceId   String @map("package_resource_id")
  componentResourceId String @map("component_resource_id")

  quantity  Decimal @db.Decimal(10, 3)
  sortOrder Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  packageResource   Resource @relation("PackageChildren", fields: [packageResourceId], references: [id], onDelete: Cascade)
  componentResource Resource @relation("PackageParents", fields: [componentResourceId], references: [id], onDelete: Cascade)

  @@unique([packageResourceId, componentResourceId])
  @@index([packageResourceId])
  @@index([componentResourceId])
  @@map("package_components")
}

// ─── Price Lists ──────────────────────────────────────────────────────────────

model PriceList {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  name         String    @db.VarChar(200)
  earlyCutoff  DateTime? @map("early_cutoff")
  normalCutoff DateTime? @map("normal_cutoff")
  discountPct  Decimal   @default(0) @map("discount_pct") @db.Decimal(5, 2)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  items        PriceListItem[]
  events       Event[]
  orders       Order[]
  ticketEvents TicketEvent[]

  @@index([tenantId, isActive])
  @@map("price_lists")
}

model PriceListItem {
  id          String   @id @default(uuid())
  priceListId String   @map("price_list_id")
  resourceId  String   @map("resource_id")
  earlyPrice  Decimal  @map("early_price") @db.Decimal(12, 2)
  normalPrice Decimal  @map("normal_price") @db.Decimal(12, 2)
  latePrice   Decimal  @map("late_price") @db.Decimal(12, 2)
  unit        String?  @db.VarChar(50)
  timeUnit    String?  @map("time_unit") @db.VarChar(20)
  detail      String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  resource  Resource  @relation(fields: [resourceId], references: [id])

  @@unique([priceListId, resourceId])
  @@map("price_list_items")
}

// ─── Clients (Exhibitors) ─────────────────────────────────────────────────────

model Client {
  id             String     @id @default(uuid())
  tenantId       String     @map("tenant_id")
  personType     PersonType @map("person_type")
  companyName    String?    @map("company_name") @db.VarChar(300)
  firstName      String?    @map("first_name") @db.VarChar(100)
  lastName       String?    @map("last_name") @db.VarChar(100)
  rfc            String?    @db.VarChar(20)
  taxRegime      String?    @map("tax_regime") @db.VarChar(200)
  email          String?    @db.VarChar(200)
  phone          String?    @db.VarChar(30)
  whatsapp       String?    @db.VarChar(30)
  addressStreet  String?    @map("address_street") @db.VarChar(300)
  addressCity    String?    @map("address_city") @db.VarChar(100)
  addressState   String?    @map("address_state") @db.VarChar(100)
  addressZip     String?    @map("address_zip") @db.VarChar(20)
  addressCountry String     @default("MX") @map("address_country") @db.VarChar(100)
  portalUserId   String?    @unique @map("portal_user_id")
  logoUrl        String?    @map("logo_url") @db.VarChar(500)
  playerNumber   String?    @map("player_number") @db.VarChar(10)
  isTeam         Boolean    @default(false) @map("is_team")
  isActive       Boolean    @default(true) @map("is_active")
  metadata       Json       @default("{}")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  tenant            Tenant              @relation(fields: [tenantId], references: [id])
  contacts          ClientContact[]
  documents         ClientDocument[]
  stands            Stand[]
  orders            Order[]             @relation("OrderClient")
  billingOrders     Order[]             @relation("OrderBillingClient")
  events            Event[]
  interactions      ClientInteraction[]
  tasks             ClientTask[]
  portalUser        PortalUser?         @relation(fields: [portalUserId], references: [id])
  portalCodes       PortalAccessCode[]
  contracts         Contract[]
  relationsFrom     ClientRelation[]    @relation("ClientRelationsFrom")
  relationsTo       ClientRelation[]    @relation("ClientRelationsTo")
  portalUserClients PortalUserClient[]
  localGames        FootballGame[]      @relation("GameLocalTeam")
  visitingGames     FootballGame[]      @relation("GameVisitingTeam")
  playerAttendance  PlayerAttendance[]

  @@index([tenantId, isActive])
  @@map("clients")
}

model ClientRelation {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  clientId       String   @map("client_id")
  relatedClientId String  @map("related_client_id")
  relationType   String   @map("relation_type") @db.VarChar(50) // BILLING, SUBSIDIARY, PARTNER, PARENT, OTHER
  notes          String?  @db.VarChar(500)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant        Tenant @relation(fields: [tenantId], references: [id])
  client        Client @relation("ClientRelationsFrom", fields: [clientId], references: [id], onDelete: Cascade)
  relatedClient Client @relation("ClientRelationsTo", fields: [relatedClientId], references: [id], onDelete: Cascade)

  @@unique([clientId, relatedClientId, relationType])
  @@index([tenantId])
  @@map("client_relations")
}

model PortalUserClient {
  id           String   @id @default(uuid())
  portalUserId String   @map("portal_user_id")
  clientId     String   @map("client_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  portalUser PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([portalUserId, clientId])
  @@map("portal_user_clients")
}

model ClientContact {
  id          String   @id @default(uuid())
  clientId    String   @map("client_id")
  contactType String   @map("contact_type") @db.VarChar(50)
  firstName   String   @map("first_name") @db.VarChar(100)
  lastName    String   @map("last_name") @db.VarChar(100)
  email       String?  @db.VarChar(200)
  phone       String?  @db.VarChar(30)
  isPrimary   Boolean  @default(false) @map("is_primary")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_contacts")
}

model ClientDocument {
  id           String   @id @default(uuid())
  clientId     String   @map("client_id")
  documentType String   @map("document_type") @db.VarChar(100)
  fileName     String   @map("file_name") @db.VarChar(300)
  blobKey      String   @map("blob_key") @db.VarChar(500)
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_documents")
}

// ─── CRM ─────────────────────────────────────────────────────────────────────

model ClientInteraction {
  id          String          @id @default(uuid())
  tenantId    String          @map("tenant_id")
  clientId    String          @map("client_id")
  type        InteractionType
  subject     String          @db.VarChar(300)
  notes       String?         @db.Text
  occurredAt  DateTime        @map("occurred_at")
  createdById String          @map("created_by_id")
  createdAt   DateTime        @default(now()) @map("created_at")

  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User         @relation("InteractionCreator", fields: [createdById], references: [id])
  tasks     ClientTask[]

  @@index([tenantId, clientId])
  @@index([tenantId, occurredAt])
  @@map("client_interactions")
}

model ClientTask {
  id            String     @id @default(uuid())
  tenantId      String     @map("tenant_id")
  clientId      String     @map("client_id")
  interactionId String?    @map("interaction_id")
  title         String     @db.VarChar(300)
  description   String?    @db.Text
  dueDate       DateTime?  @map("due_date")
  status        TaskStatus @default(PENDING)
  assignedToId  String?    @map("assigned_to_id")
  createdById   String     @map("created_by_id")
  completedAt   DateTime?  @map("completed_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  interaction ClientInteraction? @relation(fields: [interactionId], references: [id])
  assignedTo  User?              @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdBy   User               @relation("TaskCreator", fields: [createdById], references: [id])

  @@index([tenantId, clientId])
  @@index([tenantId, assignedToId, status])
  @@map("client_tasks")
}

// ─── Events ───────────────────────────────────────────────────────────────────

model Event {
  id              String      @id @default(uuid())
  tenantId        String      @map("tenant_id")
  code            String      @db.VarChar(50)
  name            String      @db.VarChar(300)
  status          EventStatus @default(QUOTED)
  description     String?     @db.Text
  venueLocation      String?     @map("venue_location") @db.VarChar(300)
  venue              String?     @db.VarChar(300)
  expectedAttendance Int?        @map("expected_attendance")
  setupStart      DateTime?   @map("setup_start")
  setupEnd        DateTime?   @map("setup_end")
  eventStart      DateTime?   @map("event_start")
  eventEnd        DateTime?   @map("event_end")
  teardownStart   DateTime?   @map("teardown_start")
  teardownEnd     DateTime?   @map("teardown_end")
  primaryClientId String?     @map("primary_client_id")
  priceListId     String?     @map("price_list_id")
  eventType       String?     @map("event_type") @db.VarChar(100)
  eventClass      String?     @map("event_class") @db.VarChar(100)
  eventCategory   String?     @map("event_category") @db.VarChar(100)
  coordinator     String?     @db.VarChar(200)
  executive       String?     @db.VarChar(200)
  portalEnabled        Boolean     @default(false) @map("portal_enabled")
  portalSlug           String?     @unique @map("portal_slug") @db.VarChar(100)
  portalSettings       Json        @default("{}") @map("portal_settings")
  sportLocalTeamId     String?     @map("sport_local_team_id")
  sportVisitingTeamId  String?     @map("sport_visiting_team_id")
  notes           String?     @db.Text
  clientNotes     String?     @map("client_notes") @db.Text
  createdById     String      @map("created_by_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tenant              Tenant             @relation(fields: [tenantId], references: [id])
  primaryClient       Client?            @relation(fields: [primaryClientId], references: [id])
  priceList           PriceList?         @relation(fields: [priceListId], references: [id])
  createdBy           User               @relation("EventCreatedBy", fields: [createdById], references: [id])
  spaces              EventSpace[]
  documents           EventDocument[]
  floorPlans          FloorPlan[]
  stands              Stand[]
  orders              Order[]
  portalAccessCodes   PortalAccessCode[]
  portalUserEvents    PortalUserEvent[]
  conversations       Conversation[]
  footballGames       FootballGame[]
  ticketEvent         TicketEvent?

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([eventStart, eventEnd])
  @@map("events")
}

model EventSpace {
  id         String     @id @default(uuid())
  eventId    String     @map("event_id")
  resourceId String     @map("resource_id")
  phase      EventPhase
  startTime  DateTime   @map("start_time")
  endTime    DateTime   @map("end_time")
  notes      String?    @db.Text
  createdAt  DateTime   @default(now()) @map("created_at")

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id])

  @@map("event_spaces")
}

model EventDocument {
  id           String   @id @default(uuid())
  eventId      String   @map("event_id")
  documentType String   @map("document_type") @db.VarChar(100)
  fileName     String   @map("file_name") @db.VarChar(300)
  blobKey      String   @map("blob_key") @db.VarChar(500)
  fileContent  Bytes?   @map("file_content")
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_documents")
}

// ─── FloorPlans ───────────────────────────────────────────────────────────────

model FloorPlan {
  id           String   @id @default(uuid())
  eventId      String   @map("event_id")
  name         String   @db.VarChar(200)
  fileUrl      String   @map("file_url") @db.VarChar(500)
  fileName     String   @map("file_name") @db.VarChar(300)
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  stands Stand[]

  @@index([eventId])
  @@map("floor_plans")
}

// ─── Stands ───────────────────────────────────────────────────────────────────

model Stand {
  id            String      @id @default(uuid())
  eventId       String      @map("event_id")
  clientId      String?     @map("client_id")
  code          String      @db.VarChar(50)
  widthM        Decimal?    @map("width_m") @db.Decimal(8, 2)
  depthM        Decimal?    @map("depth_m") @db.Decimal(8, 2)
  heightM       Decimal?    @map("height_m") @db.Decimal(8, 2)
  locationNotes String?     @map("location_notes") @db.Text
  isActive      Boolean     @default(true) @map("is_active")
  // Floor plan geometry
  floorPlanId   String?     @map("floor_plan_id")
  polygon       Json?       // [[x,y], ...] in DXF coordinate space
  dxfEntityIdx  Int?        @map("dxf_entity_idx")
  status        StandStatus @default(AVAILABLE)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  event     Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  client    Client?         @relation(fields: [clientId], references: [id])
  floorPlan FloorPlan?      @relation(fields: [floorPlanId], references: [id], onDelete: SetNull)
  documents StandDocument[]
  orders    Order[]

  @@unique([eventId, code])
  @@index([floorPlanId])
  @@map("stands")
}

model StandDocument {
  id           String   @id @default(uuid())
  standId      String   @map("stand_id")
  documentType String   @map("document_type") @db.VarChar(100)
  fileName     String   @map("file_name") @db.VarChar(300)
  blobKey      String   @map("blob_key") @db.VarChar(500)
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  stand Stand @relation(fields: [standId], references: [id], onDelete: Cascade)

  @@map("stand_documents")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(uuid())
  tenantId        String      @map("tenant_id")
  orderNumber     String      @unique @map("order_number") @db.VarChar(50)
  eventId         String      @map("event_id")
  clientId        String      @map("client_id")
  billingClientId String?     @map("billing_client_id")
  standId         String?     @map("stand_id")
  priceListId     String      @map("price_list_id")
  status          OrderStatus   @default(QUOTED)
  paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
  pricingTier     PricingTier   @map("pricing_tier")
  subtotal        Decimal     @default(0) @db.Decimal(12, 2)
  discountPct     Decimal     @default(0) @map("discount_pct") @db.Decimal(5, 2)
  discountAmount  Decimal     @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxPct          Decimal     @default(16) @map("tax_pct") @db.Decimal(5, 2)
  taxAmount       Decimal     @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total           Decimal     @default(0) @db.Decimal(12, 2)
  prospectedTotal Decimal     @default(0) @map("prospected_total") @db.Decimal(12, 2)
  paidAmount      Decimal     @default(0) @map("paid_amount") @db.Decimal(12, 2)
  notes           String?     @db.Text
  departamento    String?     @map("departamento") @db.VarChar(200)
  organizacionId  String?     @map("organizacion_id")
  isCreditNote    Boolean     @default(false) @map("is_credit_note")
  originalOrderId String?     @map("original_order_id")
  startDate       DateTime?   @map("start_date")
  endDate         DateTime?   @map("end_date")
  createdById     String      @map("created_by_id")
  assignedToId    String?     @map("assigned_to_id")
  contractId      String?     @map("contract_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  event          Event                @relation(fields: [eventId], references: [id])
  client         Client               @relation("OrderClient", fields: [clientId], references: [id])
  billingClient  Client?              @relation("OrderBillingClient", fields: [billingClientId], references: [id])
  stand          Stand?               @relation(fields: [standId], references: [id])
  priceList      PriceList            @relation(fields: [priceListId], references: [id])
  createdBy      User                 @relation("OrderCreatedBy", fields: [createdById], references: [id])
  assignedTo     User?                @relation("OrderAssignedTo", fields: [assignedToId], references: [id])
  originalOrder  Order?               @relation("CreditNoteRef", fields: [originalOrderId], references: [id])
  creditNotes    Order[]              @relation("CreditNoteRef")
  contract       Contract?            @relation(fields: [contractId], references: [id])
  organizacion   Organization?        @relation(fields: [organizacionId], references: [id])
  lineItems      OrderLineItem[]
  payments       OrderPayment[]
  documents      OrderDocument[]
  statusHistory  OrderStatusHistory[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId, status])
  @@index([tenantId, paymentStatus])
  @@index([eventId, status])
  @@index([clientId])
  @@index([orderNumber])
  @@index([contractId])
  @@map("orders")
}

model OrderLineItem {
  id           String      @id @default(uuid())
  orderId      String      @map("order_id")
  resourceId   String      @map("resource_id")
  description  String      @db.VarChar(500)
  pricingTier  PricingTier @map("pricing_tier")
  unitPrice    Decimal     @map("unit_price") @db.Decimal(12, 2)
  quantity     Decimal     @db.Decimal(10, 3)
  discountPct  Decimal     @default(0) @map("discount_pct") @db.Decimal(5, 2)
  lineTotal    Decimal     @map("line_total") @db.Decimal(12, 2)
  timeUnit     String?     @map("time_unit") @db.VarChar(20)
  detail       String?     @db.Text
  observations String?     @db.Text
  actualQuantity    Decimal?    @map("actual_quantity") @db.Decimal(10, 3)
  actualDiscountPct Decimal?    @map("actual_discount_pct") @db.Decimal(5, 2)
  actualLineTotal   Decimal?    @map("actual_line_total") @db.Decimal(12, 2)
  actualObservations String?    @map("actual_observations") @db.Text
  sortOrder    Int         @default(0) @map("sort_order")
  deliveryDate DateTime?   @map("delivery_date")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id])

  @@index([orderId])
  @@map("order_line_items")
}

model OrderPayment {
  id           String        @id @default(uuid())
  orderId      String        @map("order_id")
  method       PaymentMethod
  amount       Decimal       @db.Decimal(12, 2)
  paymentDate  DateTime      @map("payment_date")
  reference    String?       @db.VarChar(200)
  notes        String?       @db.Text
  recordedById String        @map("recorded_by_id")
  createdAt    DateTime      @default(now()) @map("created_at")

  order      Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  recordedBy User  @relation(fields: [recordedById], references: [id])

  @@index([orderId])
  @@map("order_payments")
}

model OrderDocument {
  id           String   @id @default(uuid())
  orderId      String   @map("order_id")
  documentType String   @map("document_type") @db.VarChar(100)
  fileName     String   @map("file_name") @db.VarChar(300)
  blobKey      String   @map("blob_key") @db.VarChar(500)
  fileContent  Bytes?   @map("file_content")
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  order      Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation(fields: [uploadedById], references: [id])

  @@map("order_documents")
}

model OrderStatusHistory {
  id          String       @id @default(uuid())
  orderId     String       @map("order_id")
  fromStatus  OrderStatus? @map("from_status")
  toStatus    OrderStatus  @map("to_status")
  changedById String       @map("changed_by_id")
  notes       String?      @db.Text
  createdAt   DateTime     @default(now()) @map("created_at")

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User  @relation(fields: [changedById], references: [id])

  @@index([orderId])
  @@map("order_status_history")
}

// ─── Notifications & Audit ───────────────────────────────────────────────────

model Notification {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  recipientType String    @map("recipient_type") @db.VarChar(20)
  recipientId   String    @map("recipient_id")
  channel       String    @db.VarChar(20)
  templateKey   String    @map("template_key") @db.VarChar(100)
  payload       Json
  status        String    @default("pending") @db.VarChar(20)
  sentAt        DateTime? @map("sent_at")
  errorDetails  String?   @map("error_details") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([status, createdAt])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  userId     String   @map("user_id")
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String   @map("entity_id")
  action     String   @db.VarChar(50)
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Portal de Expositores ────────────────────────────────────────────────────

model PortalUser {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id") @db.VarChar(50)
  email        String   @unique @db.VarChar(200)
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  phone        String?  @db.VarChar(30)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  client         Client?
  clients        PortalUserClient[]
  events         PortalUserEvent[]
  conversations  Conversation[]
  passwordResets PortalPasswordReset[]

  @@index([tenantId])
  @@map("portal_users")
}

model PortalPasswordReset {
  id           String   @id @default(uuid())
  portalUserId String   @map("portal_user_id")
  token        String   @unique @db.VarChar(64)
  expiresAt    DateTime @map("expires_at")
  usedAt       DateTime? @map("used_at")
  createdAt    DateTime @default(now()) @map("created_at")

  portalUser PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("portal_password_resets")
}

model PortalAccessCode {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id") @db.VarChar(50)
  eventId     String    @map("event_id")
  code        String    @unique @db.VarChar(20)
  clientId    String?   @map("client_id")
  maxUses     Int       @default(1) @map("max_uses")
  usedCount   Int       @default(0) @map("used_count")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  event     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  client    Client?           @relation(fields: [clientId], references: [id])
  createdBy User              @relation("PortalCodeCreator", fields: [createdById], references: [id])
  usages    PortalUserEvent[]

  @@index([tenantId, eventId])
  @@map("portal_access_codes")
}

model PortalUserEvent {
  id           String   @id @default(uuid())
  portalUserId String   @map("portal_user_id")
  eventId      String   @map("event_id")
  accessCodeId String   @map("access_code_id")
  createdAt    DateTime @default(now()) @map("created_at")

  portalUser PortalUser       @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  event      Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  accessCode PortalAccessCode @relation(fields: [accessCodeId], references: [id])

  @@unique([portalUserId, eventId])
  @@map("portal_user_events")
}

// ─── Chat (Colabora) ──────────────────────────────────────────────────────────

model Conversation {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  portalUserId String   @map("portal_user_id")
  eventId      String?  @map("event_id")
  subject      String?  @db.VarChar(300)
  unreadAdmin  Int      @default(0) @map("unread_admin")
  unreadPortal Int      @default(0) @map("unread_portal")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  portalUser PortalUser @relation(fields: [portalUserId], references: [id])
  event      Event?     @relation(fields: [eventId], references: [id])
  messages   Message[]

  @@index([tenantId])
  @@index([portalUserId])
  @@map("conversations")
}

model Message {
  id             String     @id @default(uuid())
  conversationId String     @map("conversation_id")
  senderType     SenderType @map("sender_type")
  senderId       String     @map("sender_id")
  senderName     String     @map("sender_name") @db.VarChar(200)
  content        String     @db.Text
  fileUrl        String?    @map("file_url") @db.VarChar(500)
  fileName       String?    @map("file_name") @db.VarChar(300)
  readAt         DateTime?  @map("read_at")
  createdAt      DateTime   @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─── Arte Capital ─────────────────────────────────────────────────────────────

model ArtCapitalUser {
  id           String             @id @default(uuid())
  tenantId     String             @map("tenant_id")
  email        String             @unique @db.VarChar(200)
  passwordHash String             @map("password_hash")
  firstName    String             @map("first_name") @db.VarChar(100)
  lastName     String             @map("last_name") @db.VarChar(100)
  phone        String?            @db.VarChar(30)
  userRole     ArtCapitalUserRole @default(COLLECTOR) @map("user_role")
  bio          String?            @db.Text
  profileImage String?            @map("profile_image") @db.VarChar(500)
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  tenant           Tenant                   @relation(fields: [tenantId], references: [id])
  artist           ArtCapitalArtist?
  memberships      ArtCapitalMembership[]
  orders           ArtCapitalOrder[]
  orderPayments    ArtCapitalPayment[]
  transactions     ArtCapitalTransaction[]
  productImages    ArtCapitalProductImage[] @relation("UploadedBy")
  createdProducts  ArtCapitalProduct[]      @relation("CreatedBy")
  approvedProducts ArtCapitalProduct[]      @relation("ApprovedBy")

  @@index([tenantId, isActive])
  @@index([email])
  @@map("art_capital_users")
}

model ArtCapitalArtist {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  userId         String   @unique @map("user_id")
  galleryName    String?  @map("gallery_name") @db.VarChar(200)
  commissionRate Decimal  @default(15) @map("commission_rate") @db.Decimal(5, 2)
  bankAccount    String?  @map("bank_account") @db.VarChar(100)
  bankName       String?  @map("bank_name") @db.VarChar(100)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         ArtCapitalUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  products     ArtCapitalProduct[]     @relation("Artist")
  transactions ArtCapitalTransaction[]

  @@index([tenantId])
  @@map("art_capital_artists")
}

model ArtCapitalProduct {
  id               String                   @id @default(uuid())
  tenantId         String                   @map("tenant_id")
  artistId         String                   @map("artist_id")
  createdById      String                   @map("created_by_id")
  approvedById     String?                  @map("approved_by_id")
  title            String                   @db.VarChar(300)
  description      String?                  @db.Text
  price            Decimal                  @db.Decimal(12, 2)
  status           ArtCapitalProductStatus  @default(DRAFT)
  membershipTierId String?                  @map("membership_tier_id")
  images           ArtCapitalProductImage[]
  category         String?                  @db.VarChar(100)
  metadata         Json                     @default("{}")
  isActive         Boolean                  @default(true) @map("is_active")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")
  approvedAt       DateTime?                @map("approved_at")
  rejectionReason  String?                  @map("rejection_reason") @db.Text

  tenant         Tenant                    @relation(fields: [tenantId], references: [id])
  artist         ArtCapitalArtist          @relation("Artist", fields: [artistId], references: [id])
  createdBy      ArtCapitalUser            @relation("CreatedBy", fields: [createdById], references: [id])
  approvedBy     ArtCapitalUser?           @relation("ApprovedBy", fields: [approvedById], references: [id])
  membershipTier ArtCapitalMembershipTier? @relation(fields: [membershipTierId], references: [id])
  lineItems      ArtCapitalOrderLineItem[]

  @@index([tenantId, status])
  @@index([artistId])
  @@index([createdAt])
  @@map("art_capital_products")
}

model ArtCapitalProductImage {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  uploadedById String   @map("uploaded_by_id")
  imageUrl     String   @map("image_url") @db.VarChar(500)
  displayOrder Int      @default(0) @map("display_order")
  isMainImage  Boolean  @default(false) @map("is_main_image")
  createdAt    DateTime @default(now()) @map("created_at")

  product    ArtCapitalProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  uploadedBy ArtCapitalUser    @relation("UploadedBy", fields: [uploadedById], references: [id])

  @@index([productId, displayOrder])
  @@map("art_capital_product_images")
}

model ArtCapitalMembershipTier {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  name         String   @db.VarChar(100)
  description  String?  @db.Text
  monthlyPrice Decimal  @map("monthly_price") @db.Decimal(12, 2)
  yearlyPrice  Decimal  @map("yearly_price") @db.Decimal(12, 2)
  benefits     Json     @default("[]")
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant            Tenant                 @relation(fields: [tenantId], references: [id])
  memberships       ArtCapitalMembership[]
  exclusiveProducts ArtCapitalProduct[]

  @@index([tenantId, isActive])
  @@map("art_capital_membership_tiers")
}

model ArtCapitalMembership {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  userId       String   @map("user_id")
  tierId       String   @map("tier_id")
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")
  renewalDate  DateTime @map("renewal_date")
  billingCycle String   @default("MONTHLY") @map("billing_cycle") @db.VarChar(20)
  autoRenew    Boolean  @default(true) @map("auto_renew")
  status       String   @default("ACTIVE") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant                   @relation(fields: [tenantId], references: [id])
  user   ArtCapitalUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
