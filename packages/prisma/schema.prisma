// ─── Purchase Order Module ───────────────────────────────────────────────────

model Supplier {
  id                  String         @id @default(uuid())
  tenantId            String         @map("tenant_id")
  code                String         @map("code") @db.VarChar(50)
  name                String         @db.VarChar(200)
  description         String?        @db.Text
  type                SupplierType
  status              SupplierStatus @default(ACTIVE)
  rfc                 String?        @db.VarChar(20)
  taxId               String?        @map("tax_id") @db.VarChar(50)
  fiscalRegime        String?        @map("fiscal_regime") @db.VarChar(100)
  legalName           String?        @map("legal_name") @db.VarChar(300)
  email               String?        @db.VarChar(200)
  phone               String?        @db.VarChar(30)
  whatsapp            String?        @db.VarChar(30)
  website             String?        @db.VarChar(300)
  addressStreet       String?        @map("address_street") @db.VarChar(300)
  addressCity         String?        @map("address_city") @db.VarChar(100)
  addressState        String?        @map("address_state") @db.VarChar(100)
  addressZip          String?        @map("address_zip") @db.VarChar(20)
  addressCountry      String         @default("MX") @map("address_country") @db.VarChar(100)
  defaultPaymentTerms String?        @map("default_payment_terms") @db.VarChar(100)
  averageDeliveryDays Int            @default(5) @map("average_delivery_days")
  currencyCode        String         @default("MXN") @map("currency_code") @db.VarChar(10)
  createdById         String         @map("created_by_id")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  createdBy      User                @relation(fields: [createdById], references: [id])
  contacts       SupplierContact[]
  priceLists     SupplierPriceList[]
  purchaseOrders PurchaseOrder[]
  portalCodes    SupplierPortalCode[]
  portalUsers    SupplierPortalUserSupplier[]
  conversations  SupplierConversation[]
  documents      SupplierDocument[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("suppliers")
}

model SupplierContact {
  id         String   @id @default(uuid())
  supplierId String   @map("supplier_id")
  name       String   @db.VarChar(150)
  role       String   @db.VarChar(100)
  email      String?  @db.VarChar(200)
  phone      String?  @db.VarChar(30)
  whatsapp   String?  @db.VarChar(30)
  isPrimary  Boolean  @default(false) @map("is_primary")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  supplier       Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([supplierId])
  @@map("supplier_contacts")
}

model SupplierPriceList {
  id                     String    @id @default(uuid())
  tenantId               String    @map("tenant_id")
  supplierId             String    @map("supplier_id")
  code                   String    @map("code") @db.VarChar(50)
  name                   String    @db.VarChar(200)
  description            String?   @db.Text
  validFrom              DateTime  @map("valid_from")
  validTo                DateTime? @map("valid_to")
  minOrderQty            Decimal?  @map("min_order_qty") @db.Decimal(10, 3)
  maxOrderQty            Decimal?  @map("max_order_qty") @db.Decimal(10, 3)
  volumeDiscountRules    Json      @default("[]") @map("volume_discount_rules")
  creditDays             Int       @default(30) @map("credit_days")
  currency               String    @default("MXN") @db.VarChar(10)
  profitMarginSuggestion Decimal?  @default(0) @map("profit_margin_suggestion") @db.Decimal(5, 2)
  isActive               Boolean   @default(true) @map("is_active")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  tenant         Tenant                  @relation(fields: [tenantId], references: [id])
  supplier       Supplier                @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items          SupplierPriceListItem[]
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, code])
  @@index([supplierId, isActive])
  @@index([validFrom, validTo])
  @@map("supplier_price_lists")
}

model SupplierPriceListItem {
  id                 String             @id @default(uuid())
  priceListId        String             @map("price_list_id")
  resourceId         String             @map("resource_id")
  supplierSku        String?            @map("supplier_sku") @db.VarChar(100)
  unitPrice          Decimal            @map("unit_price") @db.Decimal(12, 2)
  availabilityStatus AvailabilityStatus @default(AVAILABLE) @map("availability_status")
  estimatedAvailable Decimal?           @map("estimated_available") @db.Decimal(10, 3)
  deliveryTimeDays   Int                @default(5) @map("delivery_time_days")
  isActive           Boolean            @default(true) @map("is_active")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  priceList SupplierPriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  resource  Resource          @relation("SupplierPriceListItems", fields: [resourceId], references: [id])

  @@unique([priceListId, resourceId])
  @@index([resourceId])
  @@map("supplier_price_list_items")
}

model PurchaseOrder {
  id                   String              @id @default(uuid())
  tenantId             String              @map("tenant_id")
  supplierId           String              @map("supplier_id")
  priceListId          String?             @map("price_list_id")
  orderNumber          String              @unique @map("order_number") @db.VarChar(50)
  status               PurchaseOrderStatus @default(DRAFT)
  originOrderId        String?             @map("origin_order_id")
  requiredDeliveryDate DateTime            @map("required_delivery_date")
  deliveryLocation     String?             @map("delivery_location") @db.VarChar(300)
  contactId            String?             @map("contact_id")
  description          String?             @db.Text
  notes                String?             @db.Text
  organizacionId       String?             @map("organizacion_id")
  subtotal             Decimal             @default(0) @db.Decimal(12, 2)
  taxRate              Decimal             @default(16) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount            Decimal             @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total                Decimal             @default(0) @db.Decimal(12, 2)
  currency             String              @default("MXN") @db.VarChar(10)
  createdById          String              @map("created_by_id")
  confirmedById        String?             @map("confirmed_by_id")
  confirmedAt          DateTime?           @map("confirmed_at")
  cancelledAt          DateTime?           @map("cancelled_at")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  tenant        Tenant                       @relation(fields: [tenantId], references: [id])
  supplier      Supplier                     @relation(fields: [supplierId], references: [id])
  priceList     SupplierPriceList?           @relation(fields: [priceListId], references: [id])
  originOrder   Order?                       @relation(fields: [originOrderId], references: [id])
  contact       SupplierContact?             @relation(fields: [contactId], references: [id])
  createdBy     User                         @relation("POCreatedBy", fields: [createdById], references: [id])
  confirmedBy   User?                        @relation("POConfirmedBy", fields: [confirmedById], references: [id])
  organizacion  Organization?                @relation(fields: [organizacionId], references: [id])
  lineItems     PurchaseOrderLineItem[]
  documents     PurchaseOrderDocument[]
  statusHistory PurchaseOrderStatusHistory[]

  @@index([tenantId, status])
  @@index([supplierId])
  @@index([orderNumber])
  @@map("purchase_orders")
}

model PurchaseOrderLineItem {
  id               String   @id @default(uuid())
  poId             String   @map("po_id")
  resourceId       String   @map("resource_id")
  description      String   @db.VarChar(500)
  supplierSku      String?  @map("supplier_sku") @db.VarChar(100)
  quantity         Decimal  @db.Decimal(10, 3)
  unitPrice        Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal        Decimal  @map("line_total") @db.Decimal(12, 2)
  deliveryTimeDays Int      @default(5) @map("delivery_time_days")
  notes            String?  @db.Text
  receivedQty      Decimal  @default(0) @map("received_qty") @db.Decimal(10, 3)
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  resource      Resource      @relation("PurchaseOrderLineItems", fields: [resourceId], references: [id])

  @@index([poId])
  @@map("purchase_order_line_items")
}

model PurchaseOrderStatusHistory {
  id          String               @id @default(uuid())
  poId        String               @map("po_id")
  fromStatus  PurchaseOrderStatus? @map("from_status")
  toStatus    PurchaseOrderStatus  @map("to_status")
  changedById String               @map("changed_by_id")
  notes       String?              @db.Text
  createdAt   DateTime             @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  changedBy     User          @relation(fields: [changedById], references: [id])

  @@index([poId])
  @@map("purchase_order_status_history")
}

model PurchaseOrderDocument {
  id                  String   @id @default(uuid())
  poId                String   @map("po_id")
  documentType        String   @map("document_type") @db.VarChar(100)
  fileName            String   @map("file_name") @db.VarChar(300)
  blobKey             String   @map("blob_key") @db.VarChar(500)
  uploadedById        String   @map("uploaded_by_id")
  isVisibleToSupplier Boolean  @default(false) @map("is_visible_to_supplier")
  createdAt           DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  uploadedBy    User          @relation(fields: [uploadedById], references: [id])

  @@index([poId])
  @@map("purchase_order_documents")
}

// ─── Warehouse & Inventory ───────────────────────────────────────────────────

model Warehouse {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  code               String   @map("code") @db.VarChar(50)
  name               String   @db.VarChar(200)
  description        String?  @db.Text
  address            String?  @db.VarChar(300)
  managerId          String?  @map("manager_id")
  capacity           Int?
  specialConditions  Json     @default("{}") @map("special_conditions")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  manager   User?               @relation(fields: [managerId], references: [id])
  inventory ResourceInventory[]
  movements InventoryMovement[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("warehouses")
}

model ResourceInventory {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  resourceId       String   @map("resource_id")
  warehouseId      String   @map("warehouse_id")
  quantityTotal    Decimal  @default(0) @map("quantity_total") @db.Decimal(10, 3)
  quantityReserved Decimal  @default(0) @map("quantity_reserved") @db.Decimal(10, 3)
  minLevel         Decimal? @map("min_level") @db.Decimal(10, 3)
  maxLevel         Decimal? @map("max_level") @db.Decimal(10, 3)
  lastMovement     DateTime? @map("last_movement")
  location         String?  @db.VarChar(200)
  lotNumber        String?  @map("lot_number") @db.VarChar(100)
  serialNumber     String?  @map("serial_number") @db.VarChar(100)
  expiryDate       DateTime? @map("expiry_date")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  resource  Resource            @relation(fields: [resourceId], references: [id])
  warehouse Warehouse           @relation(fields: [warehouseId], references: [id])
  movements InventoryMovement[]

  @@unique([tenantId, resourceId, warehouseId])
  @@index([warehouseId])
  @@index([resourceId])
  @@map("resource_inventory")
}

model InventoryMovement {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  inventoryId      String   @map("inventory_id")
  warehouseId      String   @map("warehouse_id")
  resourceId       String   @map("resource_id")
  type             String   @db.VarChar(50)
  quantity         Decimal  @db.Decimal(10, 3)
  source           String?  @db.VarChar(100)
  sourceId         String?  @map("source_id") @db.VarChar(100)
  balanceBefore    Decimal  @map("balance_before") @db.Decimal(10, 3)
  balanceAfter     Decimal  @map("balance_after") @db.Decimal(10, 3)
  condition        String?  @db.VarChar(100)
  notes            String?  @db.Text
  recordedById     String   @map("recorded_by_id")
  createdAt        DateTime @default(now()) @map("created_at")

  tenant     Tenant             @relation(fields: [tenantId], references: [id])
  inventory  ResourceInventory  @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  warehouse  Warehouse          @relation(fields: [warehouseId], references: [id])
  resource   Resource           @relation(fields: [resourceId], references: [id])
  recordedBy User               @relation(fields: [recordedById], references: [id])

  @@index([tenantId, createdAt])
  @@index([inventoryId])
  @@index([warehouseId])
  @@index([resourceId])
  @@map("inventory_movements")
}

// ─── Contracts ─────────────────────────────────────────────────────────────────

model Contract {
  id             String         @id @default(uuid())
  tenantId       String         @map("tenant_id")
  contractNumber String         @unique @map("contract_number") @db.VarChar(50)
  description    String         @db.Text
  clientId       String         @map("client_id")
  status         ContractStatus @default(EN_FIRMA)
  signingDate    DateTime?      @map("signing_date")
  totalAmount    Decimal        @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount     Decimal        @default(0) @map("paid_amount") @db.Decimal(12, 2)
  notes          String?        @db.Text
  createdById    String         @map("created_by_id")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  tenant            Tenant                     @relation(fields: [tenantId], references: [id])
  client            Client                     @relation(fields: [clientId], references: [id])
  createdBy         User                       @relation("ContractCreatedBy", fields: [createdById], references: [id])
  orders            Order[]
  scheduledPayments ContractScheduledPayment[]
  documents         ContractDocument[]

  @@index([tenantId, status])
  @@index([clientId])
  @@map("contracts")
}

model ContractDocument {
  id           String   @id @default(uuid())
  contractId   String   @map("contract_id")
  documentType String   @map("document_type") @db.VarChar(100)
  fileName     String   @map("file_name") @db.VarChar(300)
  blobKey      String   @map("blob_key") @db.VarChar(500)
  fileContent  Bytes?   @map("file_content")
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("contract_documents")
}

model ContractScheduledPayment {
  id             String   @id @default(uuid())
  contractId     String   @map("contract_id")
  label          String   @db.VarChar(200)
  dueDate        DateTime @map("due_date")
  expectedAmount Decimal  @map("expected_amount") @db.Decimal(12, 2)
  paidAmount     Decimal  @default(0) @map("paid_amount") @db.Decimal(12, 2)
  status         String   @default("PENDING") @db.VarChar(20)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  contract Contract          @relation(fields: [contractId], references: [id], onDelete: Cascade)
  payments ContractPayment[]

  @@index([contractId])
  @@map("contract_scheduled_payments")
}

model ContractPayment {
  id                 String        @id @default(uuid())
  scheduledPaymentId String        @map("scheduled_payment_id")
  method             PaymentMethod
  amount             Decimal       @db.Decimal(12, 2)
  paymentDate        DateTime      @map("payment_date")
  reference          String?       @db.VarChar(200)
  notes              String?       @db.Text
  voucherKey         String?       @map("voucher_key") @db.VarChar(500)
  recordedById       String        @map("recorded_by_id")
  createdAt          DateTime      @default(now()) @map("created_at")

  scheduledPayment ContractScheduledPayment @relation(fields: [scheduledPaymentId], references: [id], onDelete: Cascade)
  recordedBy       User                     @relation(fields: [recordedById], references: [id])

  @@index([scheduledPaymentId])
  @@map("contract_payments")
}

// ─── Document Templates ────────────────────────────────────────────────────────

model DocumentTemplate {
  id           String          @id @default(uuid())
  tenantId     String          @map("tenant_id")
  name         String          @db.VarChar(200)
  description  String?         @db.Text
  context      TemplateContext
  fileName     String          @map("file_name") @db.VarChar(300)
  blobKey      String          @map("blob_key") @db.VarChar(500)
  fileContent  Bytes?          @map("file_content")
  placeholders Json            @default("[]")
  createdById  String          @map("created_by_id")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  createdBy User   @relation("TemplateCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId, context])
  @@map("document_templates")
}

// ─── Supplier Portal ─────────────────────────────────────────────────────────

model SupplierPortalUser {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  email        String
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  phone        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant         Tenant                       @relation(fields: [tenantId], references: [id])
  suppliers      SupplierPortalUserSupplier[]
  conversations  SupplierConversation[]
  passwordResets SupplierPortalPasswordReset[]

  @@unique([tenantId, email])
  @@map("supplier_portal_users")
}

model SupplierPortalCode {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  supplierId String    @map("supplier_id")
  code       String    @unique
  maxUses    Int       @default(1) @map("max_uses")
  usedCount  Int       @default(0) @map("used_count")
  expiresAt  DateTime? @map("expires_at")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")

  tenant   Tenant                       @relation(fields: [tenantId], references: [id])
  supplier Supplier                     @relation(fields: [supplierId], references: [id])
  usages   SupplierPortalUserSupplier[]

  @@map("supplier_portal_codes")
}

model SupplierPortalUserSupplier {
  id           String   @id @default(uuid())
  portalUserId String   @map("portal_user_id")
  supplierId   String   @map("supplier_id")
  accessCodeId String?  @map("access_code_id")
  createdAt    DateTime @default(now()) @map("created_at")

  portalUser SupplierPortalUser  @relation(fields: [portalUserId], references: [id])
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  accessCode SupplierPortalCode? @relation(fields: [accessCodeId], references: [id])

  @@unique([portalUserId, supplierId])
  @@map("supplier_portal_user_suppliers")
}

model SupplierPortalPasswordReset {
  id           String    @id @default(uuid())
  portalUserId String    @map("portal_user_id")
  token        String    @unique
  expiresAt    DateTime  @map("expires_at")
  usedAt       DateTime? @map("used_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  portalUser SupplierPortalUser @relation(fields: [portalUserId], references: [id])

  @@map("supplier_portal_password_resets")
}

model SupplierConversation {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  portalUserId String   @map("portal_user_id")
  supplierId   String   @map("supplier_id")
  subject      String?
  unreadAdmin  Int      @default(0) @map("unread_admin")
  unreadPortal Int      @default(0) @map("unread_portal")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant             @relation(fields: [tenantId], references: [id])
  portalUser SupplierPortalUser @relation(fields: [portalUserId], references: [id])
  supplier   Supplier           @relation(fields: [supplierId], references: [id])
  messages   SupplierMessage[]

  @@map("supplier_conversations")
}

model SupplierMessage {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderType     String   @map("sender_type")
  senderId       String   @map("sender_id")
  senderName     String   @map("sender_name")
  content        String?  @db.Text
  fileUrl        String?  @map("file_url") @db.VarChar(500)
  fileName       String?  @map("file_name") @db.VarChar(300)
  createdAt      DateTime @default(now()) @map("created_at")

  conversation SupplierConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("supplier_messages")
}

model SupplierDocument {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  supplierId    String   @map("supplier_id")
  uploaderType  String   @map("uploader_type")
  uploadedById  String   @map("uploaded_by_id")
  name          String   @db.VarChar(300)
  fileUrl       String   @map("file_url") @db.VarChar(500)
  fileName      String   @map("file_name") @db.VarChar(300)
  mimeType      String?  @map("mime_type") @db.VarChar(100)
  createdAt     DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([tenantId, supplierId])
  @@map("supplier_documents")
}

// ─── I-Flag Football ──────────────────────────────────────────────────────────

model FootballGame {
  id                String     @id @default(uuid())
  tenantId          String     @map("tenant_id")
  eventId           String     @map("event_id")
  localTeamId       String     @map("local_team_id")
  visitingTeamId    String     @map("visiting_team_id")
  status            GameStatus @default(PENDING)
  localScore        Int        @default(0) @map("local_score")
  visitingScore     Int        @default(0) @map("visiting_score")
  currentQuarter    Int        @default(1) @map("current_quarter")
  offenseTeamId     String?    @map("offense_team_id")
  currentDown       Int        @default(1) @map("current_down")
  yardsToFirst      Int        @default(10) @map("yards_to_first")
  timerSeconds      Int        @default(0) @map("timer_seconds")
  timerRunning      Boolean    @default(false) @map("timer_running")
  timerLastStarted  DateTime?  @map("timer_last_started")
  localTimeoutsH1   Int        @default(0) @map("local_timeouts_h1")
  localTimeoutsH2   Int        @default(0) @map("local_timeouts_h2")
  visitingTimeoutsH1 Int       @default(0) @map("visiting_timeouts_h1")
  visitingTimeoutsH2 Int       @default(0) @map("visiting_timeouts_h2")
  notes             String?    @db.Text
  startedAt         DateTime?  @map("started_at")
  finishedAt        DateTime?  @map("finished_at")
  createdById       String     @map("created_by_id")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  event         Event              @relation(fields: [eventId], references: [id])
  localTeam     Client             @relation("GameLocalTeam", fields: [localTeamId], references: [id])
  visitingTeam  Client             @relation("GameVisitingTeam", fields: [visitingTeamId], references: [id])
  createdBy     User               @relation(fields: [createdById], references: [id])
  attendance    PlayerAttendance[]
  gameEvents    GameEvent[]

  @@index([tenantId, eventId])
  @@map("football_games")
}

model PlayerAttendance {
  id         String   @id @default(uuid())
  gameId     String   @map("game_id")
  playerId   String   @map("player_id")
  teamId     String   @map("team_id")
  present    Boolean  @default(false)
  number     String?  @db.VarChar(10)
  position   String?  @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  game   FootballGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player Client       @relation(fields: [playerId], references: [id])

  @@unique([gameId, playerId])
  @@index([gameId, teamId])
  @@map("player_attendance")
}

model GameEvent {
  id          String        @id @default(uuid())
  gameId      String        @map("game_id")
  tenantId    String        @map("tenant_id")
  type        GameEventType
  teamId      String?       @map("team_id")
  playerId    String?       @map("player_id")
  quarter     Int?
  down        Int?
  points      Int           @default(0)
  description String?       @db.VarChar(500)
  metadata    Json          @default("{}")
  createdById String        @map("created_by_id")
  createdAt   DateTime      @default(now()) @map("created_at")

  game      FootballGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  createdBy User         @relation(fields: [createdById], references: [id])

  @@index([gameId])
  @@index([tenantId])
  @@map("game_events")
}

// ─── Ticket System ────────────────────────────────────────────────────────────

enum TicketMode {
  SECTION
  SEAT
}

enum TicketOrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

model TicketEvent {
  id           String      @id @default(uuid())
  tenantId     String      @map("tenant_id")
  eventId      String      @unique @map("event_id")
  mode         TicketMode  @default(SECTION)
  priceListId  String?     @map("price_list_id")
  slug         String      @unique @db.VarChar(100)
  active       Boolean     @default(false)
  description  String?     @db.Text
  imageUrl     String?     @map("image_url") @db.VarChar(500)
  mapImageUrl  String?     @map("map_image_url") @db.VarChar(500)
  mapData      Json?       @map("map_data")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  event     Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  priceList PriceList?  @relation(fields: [priceListId], references: [id])
  sections  TicketSection[]
  orders    TicketOrder[]

  @@index([tenantId])
  @@index([slug])
  @@map("ticket_events")
}

model TicketSection {
  id            String   @id @default(uuid())
  ticketEventId String   @map("ticket_event_id")
  resourceId    String?  @map("resource_id")
  name          String   @db.VarChar(200)
  colorHex      String   @default("#6B46C1") @map("color_hex") @db.VarChar(7)
  capacity      Int      @default(0)
  sold          Int      @default(0)
  price         Decimal  @default(0) @db.Decimal(12, 2)
  shapeType     String?  @map("shape_type") @db.VarChar(50)
  shapeData     Json?    @map("shape_data")
  labelX        Int?     @map("label_x")
  labelY        Int?     @map("label_y")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  ticketEvent TicketEvent    @relation(fields: [ticketEventId], references: [id], onDelete: Cascade)
  resource    Resource?      @relation(fields: [resourceId], references: [id])
  seats       TicketSeat[]
  orderItems  TicketOrderItem[]

  @@index([ticketEventId])
  @@map("ticket_sections")
}

model TicketSeat {
  id        String   @id @default(uuid())
  sectionId String   @map("section_id")
  row       String   @db.VarChar(10)
  number    Int
  status    String   @default("AVAILABLE") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  section    TicketSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  orderItems TicketOrderItem[]

  @@unique([sectionId, row, number])
  @@index([sectionId])
  @@map("ticket_seats")
}

model TicketOrder {
  id              String            @id @default(uuid())
  tenantId        String            @map("tenant_id")
  ticketEventId   String            @map("ticket_event_id")
  buyerEmail      String            @map("buyer_email") @db.VarChar(300)
  buyerName       String            @map("buyer_name") @db.VarChar(300)
  buyerPhone      String?           @map("buyer_phone") @db.VarChar(50)
  stripeSessionId String?           @map("stripe_session_id") @db.VarChar(300)
  stripePaymentId String?           @map("stripe_payment_id") @db.VarChar(300)
  status          TicketOrderStatus @default(PENDING)
  total           Decimal           @default(0) @db.Decimal(12, 2)
  token           String            @unique @default(uuid())
  expiresAt       DateTime?         @map("expires_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  ticketEvent TicketEvent       @relation(fields: [ticketEventId], references: [id])
  items       TicketOrderItem[]

  @@index([tenantId, status])
  @@index([stripeSessionId])
  @@index([token])
  @@map("ticket_orders")
}

model TicketOrderItem {
  id            String  @id @default(uuid())
  ticketOrderId String  @map("ticket_order_id")
  sectionId     String  @map("section_id")
  seatId        String? @map("seat_id")
  quantity      Int     @default(1)
  unitPrice     Decimal @map("unit_price") @db.Decimal(12, 2)
  lineTotal     Decimal @map("line_total") @db.Decimal(12, 2)

  ticketOrder TicketOrder   @relation(fields: [ticketOrderId], references: [id], onDelete: Cascade)
  section     TicketSection @relation(fields: [sectionId], references: [id])
  seat        TicketSeat?   @relation(fields: [seatId], references: [id])

  @@index([ticketOrderId])
  @@map("ticket_order_items")
}
