generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output        = "../../node_modules/prisma-generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ResourceType {
  CONSUMABLE
  EQUIPMENT
  SPACE
  FURNITURE
  SERVICE
  DISCOUNT
  TAX
  PERSONAL
}

enum DepartmentType {
  INTERNAL
  EXTERNAL
}

enum EventStatus {
  QUOTED
  CONFIRMED
  IN_EXECUTION
  CLOSED
  CANCELLED
}

enum EventPhase {
  SETUP
  EVENT
  TEARDOWN
}

enum OrderStatus {
  QUOTED
  CONFIRMED
  IN_PAYMENT
  PAID
  INVOICED
  CANCELLED
  CREDIT_NOTE
}

enum PersonType {
  PHYSICAL
  MORAL
}

enum UserRole {
  ADMIN
  NORMAL
  READ_ONLY
}

enum PaymentMethod {
  CASH
  TRANSFER
  CREDIT_CARD
  CHECK
  SWIFT
}

enum PricingTier {
  EARLY
  NORMAL
  LATE
}

enum InteractionType {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  NOTE
}

enum TaskStatus {
  PENDING
  DONE
  CANCELLED
}

enum SenderType {
  ADMIN
  PORTAL_USER
}

enum SupplierType {
  DISTRIBUTOR
  MANUFACTURER
  WHOLESALER
  SERVICES
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum PurchaseOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  INVOICED
  CANCELLED
}

enum AvailabilityStatus {
  AVAILABLE
  BY_ORDER
  DISCONTINUED
  TEMPORARILY_OUT
}

enum ArtCapitalUserRole {
  ARTIST
  COLLECTOR
  ADMIN
}

enum ArtCapitalOrderStatus {
  QUOTED
  CONFIRMED
  IN_PAYMENT
  PAID
  INVOICED
  CANCELLED
  CREDIT_NOTE
}

enum ArtCapitalProductStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ARCHIVED
}

enum ArtworkStatus {
  AVAILABLE
  SOLD
  RESERVED
  ARCHIVED
}

enum ArtMedium {
  OIL
  ACRYLIC
  WATERCOLOR
  SCULPTURE
  PHOTOGRAPHY
  PRINT
  DIGITAL
  MIXED_MEDIA
}

enum ArtStyle {
  IMPRESSIONISM
  SURREALISM
  POP_ART
  CUBISM
  ABSTRACT
  REALISM
  EXPRESSIONISM
  CONTEMPORARY
  TRADITIONAL
  MODERNISM
}

enum GalleryOrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ClassStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

// ─── Multi-tenancy ────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(200)
  slug      String   @unique @db.VarChar(100)
  settings  Json     @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users             User[]
  departments       Department[]
  resources         Resource[]
  priceLists        PriceList[]
  clients           Client[]
  events            Event[]
  orders            Order[]
  notifications     Notification[]
  interactions      ClientInteraction[]
  clientTasks       ClientTask[]
  portalUsers       PortalUser[]
  portalAccessCodes PortalAccessCode[]
  conversations     Conversation[]

  // Arte Capital
  artCapitalUsers           ArtCapitalUser[]
  artCapitalMembershipTiers ArtCapitalMembershipTier[]
  artCapitalProducts        ArtCapitalProduct[]
  artCapitalOrders          ArtCapitalOrder[]
  artCapitalMemberships     ArtCapitalMembership[]
  artCapitalTransactions    ArtCapitalTransaction[]

  // Gallery
  galleryArtworks         GalleryArtwork[]
  galleryArtists          GalleryArtist[]
  galleryCollections      GalleryCollection[]
  galleryLocations        GalleryLocation[]
  galleryMemberships      GalleryMembership[]
  galleryClasses          GalleryClass[]
  galleryClassEnrollments GalleryClassEnrollment[]
  galleryExhibitions      GalleryExhibition[]
  galleryCarts            GalleryCart[]
  galleryCartItems        GalleryCartItem[]
  galleryOrders           GalleryOrder[]
  galleryOrderLineItems   GalleryOrderLineItem[]
  galleryFavorites        GalleryFavorite[]

  // Purchase Order Module
  suppliers          Supplier[]
  supplierPriceLists SupplierPriceList[]
  purchaseOrders     PurchaseOrder[]

  @@map("tenants")
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  email        String   @unique @db.VarChar(200)
  passwordHash String?  @map("password_hash")
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  phone        String?  @db.VarChar(30)
  role         UserRole @default(NORMAL)
  isActive     Boolean  @default(true) @map("is_active")
  azureAdId    String?  @map("azure_ad_id") @db.VarChar(200)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant              Tenant                       @relation(fields: [tenantId], references: [id])
  userDepartments     UserDepartment[]
  privileges          UserPrivilege[]
  createdEvents       Event[]                      @relation("EventCreatedBy")
  createdOrders       Order[]                      @relation("OrderCreatedBy")
  assignedOrders      Order[]                      @relation("OrderAssignedTo")
  recordedPayments    OrderPayment[]
  uploadedDocuments   OrderDocument[]
  statusHistory       OrderStatusHistory[]
  auditLogs           AuditLog[]
  createdInteractions ClientInteraction[]          @relation("InteractionCreator")
  assignedTasks       ClientTask[]                 @relation("TaskAssignee")
  createdTasks        ClientTask[]                 @relation("TaskCreator")
  createdPortalCodes  PortalAccessCode[]           @relation("PortalCodeCreator")
  createdSuppliers    Supplier[]
  poCreatedBy         PurchaseOrder[]              @relation("POCreatedBy")
  poConfirmedBy       PurchaseOrder[]              @relation("POConfirmedBy")
  poStatusHistory     PurchaseOrderStatusHistory[]
  poDocuments         PurchaseOrderDocument[]

  @@index([tenantId, isActive])
  @@map("users")
}

model UserDepartment {
  userId       String @map("user_id")
  departmentId String @map("department_id")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([userId, departmentId])
  @@map("user_departments")
}

model UserPrivilege {
  id           String  @id @default(uuid())
  userId       String  @map("user_id")
  privilegeKey String  @map("privilege_key") @db.VarChar(100)
  granted      Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, privilegeKey])
  @@map("user_privileges")
}

// ─── Departments ──────────────────────────────────────────────────────────────

model Department {
  id        String         @id @default(uuid())
  tenantId  String         @map("tenant_id")
  name      String         @db.VarChar(200)
  type      DepartmentType @default(INTERNAL)
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  userDepartments UserDepartment[]
  resources       Resource[]

  @@index([tenantId, isActive])
  @@map("departments")
}

// ─── Resources (Products & Services) ─────────────────────────────────────────

model Resource {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  code           String       @db.VarChar(50)
  name           String       @db.VarChar(200)
  type           ResourceType
  description    String?      @db.Text
  unit           String?      @db.VarChar(50)
  stock          Int          @default(0)
  stockLocation  String?      @map("stock_location") @db.VarChar(200)
  checkStock     Boolean      @default(false) @map("check_stock")
  checkDuplicate Boolean      @default(false) @map("check_duplicate")
  recoveryTime   Int          @default(0) @map("recovery_time")
  areaSqm        Decimal?     @map("area_sqm") @db.Decimal(10, 2)
  capacity       Int?
  departmentId   String?      @map("department_id")
  portalVisible  Boolean      @default(false) @map("portal_visible")
  portalDesc     String?      @map("portal_desc") @db.Text
  portalBlobKey  String?      @map("portal_blob_key") @db.VarChar(500)
  imageMain      String?      @map("image_main") @db.VarChar(500)
  imageDesc      String?      @map("image_desc") @db.VarChar(500)
  imageExtra     String?      @map("image_extra") @db.VarChar(500)
  isPackage      Boolean      @default(false) @map("is_package")
  isSubstitute   Boolean      @default(false) @map("is_substitute")

  isActive  Boolean  @default(true) @map("is_active")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant             Tenant                  @relation(fields: [tenantId], references: [id])
  department         Department?             @relation(fields: [departmentId], references: [id])
  priceListItems     PriceListItem[]
  eventSpaces        EventSpace[]
  orderLineItems     OrderLineItem[]
  packageComponents  PackageComponent[]      @relation("PackageChildren")
  parentPackages     PackageComponent[]      @relation("PackageParents")
  supplierPriceItems SupplierPriceListItem[] @relation("SupplierPriceListItems")
  purchaseOrderItems PurchaseOrderLineItem[] @relation("PurchaseOrderLineItems")

  @@unique([tenantId, code])
  @@index([tenantId, type, isActive])
  @@index([tenantId, isPackage])
  @@map("resources")
}

// ─── Package Components ───────────────────────────────────────────────────────

model PackageComponent {
  id                  String @id @default(uuid())
  packageResourceId   String @map("package_resource_id")
  componentResourceId String @map("component_resource_id")

  quantity  Decimal @db.Decimal(10, 3)
  sortOrder Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  packageResource   Resource @relation("PackageChildren", fields: [packageResourceId], references: [id], onDelete: Cascade)
  componentResource Resource @relation("PackageParents", fields: [componentResourceId], references: [id], onDelete: Cascade)

  @@unique([packageResourceId, componentResourceId])
  @@index([packageResourceId])
  @@index([componentResourceId])
  @@map("package_components")
}

// ─── Price Lists ──────────────────────────────────────────────────────────────

model PriceList {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  name         String    @db.VarChar(200)
  earlyCutoff  DateTime? @map("early_cutoff")
  normalCutoff DateTime? @map("normal_cutoff")
  discountPct  Decimal   @default(0) @map("discount_pct") @db.Decimal(5, 2)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  items  PriceListItem[]
  events Event[]
  orders Order[]

  @@index([tenantId, isActive])
  @@map("price_lists")
}

model PriceListItem {
  id          String   @id @default(uuid())
  priceListId String   @map("price_list_id")
  resourceId  String   @map("resource_id")
  earlyPrice  Decimal  @map("early_price") @db.Decimal(12, 2)
  normalPrice Decimal  @map("normal_price") @db.Decimal(12, 2)
  latePrice   Decimal  @map("late_price") @db.Decimal(12, 2)
  unit        String?  @db.VarChar(50)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  resource  Resource  @relation(fields: [resourceId], references: [id])

  @@unique([priceListId, resourceId])
  @@map("price_list_items")
}

// ─── Clients (Exhibitors) ─────────────────────────────────────────────────────

model Client {
  id             String     @id @default(uuid())
  tenantId       String     @map("tenant_id")
  personType     PersonType @map("person_type")
  companyName    String?    @map("company_name") @db.VarChar(300)
  firstName      String?    @map("first_name") @db.VarChar(100)
  lastName       String?    @map("last_name") @db.VarChar(100)
  rfc            String?    @db.VarChar(20)
  taxRegime      String?    @map("tax_regime") @db.VarChar(200)
  email          String?    @db.VarChar(200)
  phone          String?    @db.VarChar(30)
  whatsapp       String?    @db.VarChar(30)
  addressStreet  String?    @map("address_street") @db.VarChar(300)
  addressCity    String?    @map("address_city") @db.VarChar(100)
  addressState   String?    @map("address_state") @db.VarChar(100)
  addressZip     String?    @map("address_zip") @db.VarChar(20)
  addressCountry String     @default("MX") @map("address_country") @db.VarChar(100)
  portalUserId   String?    @unique @map("portal_user_id")
  isActive       Boolean    @default(true) @map("is_active")
  metadata       Json       @default("{}")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  contacts      ClientContact[]
  documents     ClientDocument[]
  stands        Stand[]
  orders        Order[]             @relation("OrderClient")
  billingOrders Order[]             @relation("OrderBillingClient")
  events        Event[]
  interactions  ClientInteraction[]
  tasks         ClientTask[]
  portalUser    PortalUser?         @relation(fields: [portalUserId], references: [id])
  portalCodes   PortalAccessCode[]

  @@index([tenantId, isActive])
  @@map("clients")
}

model ClientContact {
  id          String   @id @default(uuid())
  clientId    String   @map("client_id")
  contactType String   @map("contact_type") @db.VarChar(50)
  firstName   String   @map("first_name") @db.VarChar(100)
  lastName    String   @map("last_name") @db.VarChar(100)
  email       String?  @db.VarChar(200)
  phone       String?  @db.VarChar(30)
  isPrimary   Boolean  @default(false) @map("is_primary")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_contacts")
}

model ClientDocument {
  id           String   @id @default(uuid())
  clientId     String   @map("client_id")
  documentType String   @map("document_type") @db.VarChar(100)
  fileName     String   @map("file_name") @db.VarChar(300)
  blobKey      String   @map("blob_key") @db.VarChar(500)
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_documents")
}

// ─── CRM ─────────────────────────────────────────────────────────────────────

model ClientInteraction {
  id          String          @id @default(uuid())
  tenantId    String          @map("tenant_id")
  clientId    String          @map("client_id")
  type        InteractionType
  subject     String          @db.VarChar(300)
  notes       String?         @db.Text
  occurredAt  DateTime        @map("occurred_at")
  createdById String          @map("created_by_id")
  createdAt   DateTime        @default(now()) @map("created_at")

  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User         @relation("InteractionCreator", fields: [createdById], references: [id])
  tasks     ClientTask[]

  @@index([tenantId, clientId])
  @@index([tenantId, occurredAt])
  @@map("client_interactions")
}

model ClientTask {
  id            String     @id @default(uuid())
  tenantId      String     @map("tenant_id")
  clientId      String     @map("client_id")
  interactionId String?    @map("interaction_id")
  title         String     @db.VarChar(300)
  description   String?    @db.Text
  dueDate       DateTime?  @map("due_date")
  status        TaskStatus @default(PENDING)
  assignedToId  String?    @map("assigned_to_id")
  createdById   String     @map("created_by_id")
  completedAt   DateTime?  @map("completed_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  interaction ClientInteraction? @relation(fields: [interactionId], references: [id])
  assignedTo  User?              @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdBy   User               @relation("TaskCreator", fields: [createdById], references: [id])

  @@index([tenantId, clientId])
  @@index([tenantId, assignedToId, status])
  @@map("client_tasks")
}

// ─── Events ───────────────────────────────────────────────────────────────────

model Event {
  id              String      @id @default(uuid())
  tenantId        String      @map("tenant_id")
  code            String      @db.VarChar(50)
  name            String      @db.VarChar(300)
  status          EventStatus @default(QUOTED)
  description     String?     @db.Text
  venueLocation   String?     @map("venue_location") @db.VarChar(300)
  setupStart      DateTime?   @map("setup_start")
  setupEnd        DateTime?   @map("setup_end")
  eventStart      DateTime?   @map("event_start")
  eventEnd        DateTime?   @map("event_end")
  teardownStart   DateTime?   @map("teardown_start")
  teardownEnd     DateTime?   @map("teardown_end")
  primaryClientId String?     @map("primary_client_id")
  priceListId     String?     @map("price_list_id")
  eventType       String?     @map("event_type") @db.VarChar(100)
  eventClass      String?     @map("event_class") @db.VarChar(100)
  eventCategory   String?     @map("event_category") @db.VarChar(100)
  coordinator     String?     @db.VarChar(200)
  executive       String?     @db.VarChar(200)
  portalEnabled   Boolean     @default(false) @map("portal_enabled")
  portalSlug      String?     @unique @map("portal_slug") @db.VarChar(100)
  portalSettings  Json        @default("{}") @map("portal_settings")
  notes           String?     @db.Text
  clientNotes     String?     @map("client_notes") @db.Text
  createdById     String      @map("created_by_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  primaryClient     Client?            @relation(fields: [primaryClientId], references: [id])
  priceList         PriceList?         @relation(fields: [priceListId], references: [id])
  createdBy         User               @relation("EventCreatedBy", fields: [createdById], references: [id])
  spaces            EventSpace[]
  documents         EventDocument[]
  stands            Stand[]
  orders            Order[]
  portalAccessCodes PortalAccessCode[]
  portalUserEvents  PortalUserEvent[]
  conversations     Conversation[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([eventStart, eventEnd])
  @@map("events")
}

model EventSpace {
  id         String     @id @default(uuid())
  eventId    String     @map("event_id")
  resourceId String     @map("resource_id")
  phase      EventPhase
  startTime  DateTime   @map("start_time")
  endTime    DateTime   @map("end_time")
  notes      String?    @db.Text
  createdAt  DateTime   @default(now()) @map("created_at")

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id])

  @@map("event_spaces")
}

model EventDocument {
  id           String   @id @default(uuid())
  eventId      String   @map("event_id")
  documentType String   @map("document_type") @db.VarChar(100)
  fileName     String   @map("file_name") @db.VarChar(300)
  blobKey      String   @map("blob_key") @db.VarChar(500)
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_documents")
}

// ─── Stands ───────────────────────────────────────────────────────────────────

model Stand {
  id            String   @id @default(uuid())
  eventId       String   @map("event_id")
  clientId      String?  @map("client_id")
  code          String   @db.VarChar(50)
  widthM        Decimal? @map("width_m") @db.Decimal(8, 2)
  depthM        Decimal? @map("depth_m") @db.Decimal(8, 2)
  heightM       Decimal? @map("height_m") @db.Decimal(8, 2)
  locationNotes String?  @map("location_notes") @db.Text
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  event     Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  client    Client?         @relation(fields: [clientId], references: [id])
  documents StandDocument[]
  orders    Order[]

  @@unique([eventId, code])
  @@map("stands")
}

model StandDocument {
  id           String   @id @default(uuid())
  standId      String   @map("stand_id")
  documentType String   @map("document_type") @db.VarChar(100)
  fileName     String   @map("file_name") @db.VarChar(300)
  blobKey      String   @map("blob_key") @db.VarChar(500)
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  stand Stand @relation(fields: [standId], references: [id], onDelete: Cascade)

  @@map("stand_documents")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(uuid())
  tenantId        String      @map("tenant_id")
  orderNumber     String      @unique @map("order_number") @db.VarChar(50)
  eventId         String      @map("event_id")
  clientId        String      @map("client_id")
  billingClientId String?     @map("billing_client_id")
  standId         String?     @map("stand_id")
  priceListId     String      @map("price_list_id")
  status          OrderStatus @default(QUOTED)
  pricingTier     PricingTier @map("pricing_tier")
  subtotal        Decimal     @default(0) @db.Decimal(12, 2)
  discountPct     Decimal     @default(0) @map("discount_pct") @db.Decimal(5, 2)
  discountAmount  Decimal     @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxPct          Decimal     @default(16) @map("tax_pct") @db.Decimal(5, 2)
  taxAmount       Decimal     @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total           Decimal     @default(0) @db.Decimal(12, 2)
  prospectedTotal Decimal     @default(0) @map("prospected_total") @db.Decimal(12, 2)
  paidAmount      Decimal     @default(0) @map("paid_amount") @db.Decimal(12, 2)
  notes           String?     @db.Text
  isCreditNote    Boolean     @default(false) @map("is_credit_note")
  originalOrderId String?     @map("original_order_id")
  startDate       DateTime?   @map("start_date")
  endDate         DateTime?   @map("end_date")
  createdById     String      @map("created_by_id")
  assignedToId    String?     @map("assigned_to_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  event          Event                @relation(fields: [eventId], references: [id])
  client         Client               @relation("OrderClient", fields: [clientId], references: [id])
  billingClient  Client?              @relation("OrderBillingClient", fields: [billingClientId], references: [id])
  stand          Stand?               @relation(fields: [standId], references: [id])
  priceList      PriceList            @relation(fields: [priceListId], references: [id])
  createdBy      User                 @relation("OrderCreatedBy", fields: [createdById], references: [id])
  assignedTo     User?                @relation("OrderAssignedTo", fields: [assignedToId], references: [id])
  originalOrder  Order?               @relation("CreditNoteRef", fields: [originalOrderId], references: [id])
  creditNotes    Order[]              @relation("CreditNoteRef")
  lineItems      OrderLineItem[]
  payments       OrderPayment[]
  documents      OrderDocument[]
  statusHistory  OrderStatusHistory[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId, status])
  @@index([eventId, status])
  @@index([clientId])
  @@index([orderNumber])
  @@map("orders")
}

model OrderLineItem {
  id           String      @id @default(uuid())
  orderId      String      @map("order_id")
  resourceId   String      @map("resource_id")
  description  String      @db.VarChar(500)
  pricingTier  PricingTier @map("pricing_tier")
  unitPrice    Decimal     @map("unit_price") @db.Decimal(12, 2)
  quantity     Decimal     @db.Decimal(10, 3)
  discountPct  Decimal     @default(0) @map("discount_pct") @db.Decimal(5, 2)
  lineTotal    Decimal     @map("line_total") @db.Decimal(12, 2)
  observations String?     @db.Text
  sortOrder    Int         @default(0) @map("sort_order")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id])

  @@index([orderId])
  @@map("order_line_items")
}

model OrderPayment {
  id           String        @id @default(uuid())
  orderId      String        @map("order_id")
  method       PaymentMethod
  amount       Decimal       @db.Decimal(12, 2)
  paymentDate  DateTime      @map("payment_date")
  reference    String?       @db.VarChar(200)
  notes        String?       @db.Text
  recordedById String        @map("recorded_by_id")
  createdAt    DateTime      @default(now()) @map("created_at")

  order      Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  recordedBy User  @relation(fields: [recordedById], references: [id])

  @@index([orderId])
  @@map("order_payments")
}

model OrderDocument {
  id           String   @id @default(uuid())
  orderId      String   @map("order_id")
  documentType String   @map("document_type") @db.VarChar(100)
  fileName     String   @map("file_name") @db.VarChar(300)
  blobKey      String   @map("blob_key") @db.VarChar(500)
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  order      Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation(fields: [uploadedById], references: [id])

  @@map("order_documents")
}

model OrderStatusHistory {
  id          String       @id @default(uuid())
  orderId     String       @map("order_id")
  fromStatus  OrderStatus? @map("from_status")
  toStatus    OrderStatus  @map("to_status")
  changedById String       @map("changed_by_id")
  notes       String?      @db.Text
  createdAt   DateTime     @default(now()) @map("created_at")

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User  @relation(fields: [changedById], references: [id])

  @@index([orderId])
  @@map("order_status_history")
}

// ─── Notifications & Audit ───────────────────────────────────────────────────

model Notification {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  recipientType String    @map("recipient_type") @db.VarChar(20)
  recipientId   String    @map("recipient_id")
  channel       String    @db.VarChar(20)
  templateKey   String    @map("template_key") @db.VarChar(100)
  payload       Json
  status        String    @default("pending") @db.VarChar(20)
  sentAt        DateTime? @map("sent_at")
  errorDetails  String?   @map("error_details") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([status, createdAt])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  userId     String   @map("user_id")
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String   @map("entity_id")
  action     String   @db.VarChar(50)
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Portal de Expositores ────────────────────────────────────────────────────

model PortalUser {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id") @db.VarChar(50)
  email        String   @unique @db.VarChar(200)
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  phone        String?  @db.VarChar(30)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  client        Client?
  events        PortalUserEvent[]
  conversations Conversation[]

  @@index([tenantId])
  @@map("portal_users")
}

model PortalAccessCode {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id") @db.VarChar(50)
  eventId     String    @map("event_id")
  code        String    @unique @db.VarChar(20)
  clientId    String?   @map("client_id")
  maxUses     Int       @default(1) @map("max_uses")
  usedCount   Int       @default(0) @map("used_count")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  event     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  client    Client?           @relation(fields: [clientId], references: [id])
  createdBy User              @relation("PortalCodeCreator", fields: [createdById], references: [id])
  usages    PortalUserEvent[]

  @@index([tenantId, eventId])
  @@map("portal_access_codes")
}

model PortalUserEvent {
  id           String   @id @default(uuid())
  portalUserId String   @map("portal_user_id")
  eventId      String   @map("event_id")
  accessCodeId String   @map("access_code_id")
  createdAt    DateTime @default(now()) @map("created_at")

  portalUser PortalUser       @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  event      Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  accessCode PortalAccessCode @relation(fields: [accessCodeId], references: [id])

  @@unique([portalUserId, eventId])
  @@map("portal_user_events")
}

// ─── Chat (Colabora) ──────────────────────────────────────────────────────────

model Conversation {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  portalUserId String   @map("portal_user_id")
  eventId      String?  @map("event_id")
  subject      String?  @db.VarChar(300)
  unreadAdmin  Int      @default(0) @map("unread_admin")
  unreadPortal Int      @default(0) @map("unread_portal")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  portalUser PortalUser @relation(fields: [portalUserId], references: [id])
  event      Event?     @relation(fields: [eventId], references: [id])
  messages   Message[]

  @@index([tenantId])
  @@index([portalUserId])
  @@map("conversations")
}

model Message {
  id             String     @id @default(uuid())
  conversationId String     @map("conversation_id")
  senderType     SenderType @map("sender_type")
  senderId       String     @map("sender_id")
  senderName     String     @map("sender_name") @db.VarChar(200)
  content        String     @db.Text
  fileUrl        String?    @map("file_url") @db.VarChar(500)
  fileName       String?    @map("file_name") @db.VarChar(300)
  readAt         DateTime?  @map("read_at")
  createdAt      DateTime   @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─── Arte Capital ─────────────────────────────────────────────────────────────

model ArtCapitalUser {
  id           String             @id @default(uuid())
  tenantId     String             @map("tenant_id")
  email        String             @unique @db.VarChar(200)
  passwordHash String             @map("password_hash")
  firstName    String             @map("first_name") @db.VarChar(100)
  lastName     String             @map("last_name") @db.VarChar(100)
  phone        String?            @db.VarChar(30)
  userRole     ArtCapitalUserRole @default(COLLECTOR) @map("user_role")
  bio          String?            @db.Text
  profileImage String?            @map("profile_image") @db.VarChar(500)
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  tenant           Tenant                   @relation(fields: [tenantId], references: [id])
  artist           ArtCapitalArtist?
  memberships      ArtCapitalMembership[]
  orders           ArtCapitalOrder[]
  orderPayments    ArtCapitalPayment[]
  transactions     ArtCapitalTransaction[]
  productImages    ArtCapitalProductImage[] @relation("UploadedBy")
  createdProducts  ArtCapitalProduct[]      @relation("CreatedBy")
  approvedProducts ArtCapitalProduct[]      @relation("ApprovedBy")

  @@index([tenantId, isActive])
  @@index([email])
  @@map("art_capital_users")
}

model ArtCapitalArtist {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  userId         String   @unique @map("user_id")
  galleryName    String?  @map("gallery_name") @db.VarChar(200)
  commissionRate Decimal  @default(15) @map("commission_rate") @db.Decimal(5, 2)
  bankAccount    String?  @map("bank_account") @db.VarChar(100)
  bankName       String?  @map("bank_name") @db.VarChar(100)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         ArtCapitalUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  products     ArtCapitalProduct[]     @relation("Artist")
  transactions ArtCapitalTransaction[]

  @@index([tenantId])
  @@map("art_capital_artists")
}

model ArtCapitalProduct {
  id               String                   @id @default(uuid())
  tenantId         String                   @map("tenant_id")
  artistId         String                   @map("artist_id")
  createdById      String                   @map("created_by_id")
  approvedById     String?                  @map("approved_by_id")
  title            String                   @db.VarChar(300)
  description      String?                  @db.Text
  price            Decimal                  @db.Decimal(12, 2)
  status           ArtCapitalProductStatus  @default(DRAFT)
  membershipTierId String?                  @map("membership_tier_id")
  images           ArtCapitalProductImage[]
  category         String?                  @db.VarChar(100)
  metadata         Json                     @default("{}")
  isActive         Boolean                  @default(true) @map("is_active")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")
  approvedAt       DateTime?                @map("approved_at")
  rejectionReason  String?                  @map("rejection_reason") @db.Text

  tenant         Tenant                    @relation(fields: [tenantId], references: [id])
  artist         ArtCapitalArtist          @relation("Artist", fields: [artistId], references: [id])
  createdBy      ArtCapitalUser            @relation("CreatedBy", fields: [createdById], references: [id])
  approvedBy     ArtCapitalUser?           @relation("ApprovedBy", fields: [approvedById], references: [id])
  membershipTier ArtCapitalMembershipTier? @relation(fields: [membershipTierId], references: [id])
  lineItems      ArtCapitalOrderLineItem[]

  @@index([tenantId, status])
  @@index([artistId])
  @@index([createdAt])
  @@map("art_capital_products")
}

model ArtCapitalProductImage {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  uploadedById String   @map("uploaded_by_id")
  imageUrl     String   @map("image_url") @db.VarChar(500)
  displayOrder Int      @default(0) @map("display_order")
  isMainImage  Boolean  @default(false) @map("is_main_image")
  createdAt    DateTime @default(now()) @map("created_at")

  product    ArtCapitalProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  uploadedBy ArtCapitalUser    @relation("UploadedBy", fields: [uploadedById], references: [id])

  @@index([productId, displayOrder])
  @@map("art_capital_product_images")
}

model ArtCapitalMembershipTier {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  name         String   @db.VarChar(100)
  description  String?  @db.Text
  monthlyPrice Decimal  @map("monthly_price") @db.Decimal(12, 2)
  yearlyPrice  Decimal  @map("yearly_price") @db.Decimal(12, 2)
  benefits     Json     @default("[]")
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant            Tenant                 @relation(fields: [tenantId], references: [id])
  memberships       ArtCapitalMembership[]
  exclusiveProducts ArtCapitalProduct[]

  @@index([tenantId, isActive])
  @@map("art_capital_membership_tiers")
}

model ArtCapitalMembership {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  userId       String   @map("user_id")
  tierId       String   @map("tier_id")
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")
  renewalDate  DateTime @map("renewal_date")
  billingCycle String   @default("MONTHLY") @map("billing_cycle") @db.VarChar(20)
  autoRenew    Boolean  @default(true) @map("auto_renew")
  status       String   @default("ACTIVE") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant                   @relation(fields: [tenantId], references: [id])
  user   ArtCapitalUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier   ArtCapitalMembershipTier @relation(fields: [tierId], references: [id])

  @@unique([userId, tierId])
  @@index([tenantId, endDate])
  @@index([renewalDate])
  @@map("art_capital_memberships")
}

model ArtCapitalOrder {
  id             String                @id @default(uuid())
  tenantId       String                @map("tenant_id")
  userId         String                @map("user_id")
  orderNumber    String                @unique @db.VarChar(50)
  status         ArtCapitalOrderStatus @default(QUOTED)
  subtotal       Decimal               @db.Decimal(12, 2)
  discountAmount Decimal               @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount      Decimal               @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total          Decimal               @db.Decimal(12, 2)
  paidAmount     Decimal               @default(0) @map("paid_amount") @db.Decimal(12, 2)
  notes          String?               @db.Text
  metadata       Json                  @default("{}")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  tenant       Tenant                    @relation(fields: [tenantId], references: [id])
  user         ArtCapitalUser            @relation(fields: [userId], references: [id], onDelete: Cascade)
  lineItems    ArtCapitalOrderLineItem[]
  payments     ArtCapitalPayment[]
  transactions ArtCapitalTransaction[]

  @@index([tenantId, createdAt])
  @@index([userId])
  @@index([status])
  @@map("art_capital_orders")
}

model ArtCapitalOrderLineItem {
  id             String   @id @default(uuid())
  orderId        String   @map("order_id")
  productId      String   @map("product_id")
  quantity       Int      @default(1)
  unitPrice      Decimal  @map("unit_price") @db.Decimal(12, 2)
  discountAmount Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount      Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  subtotal       Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  order   ArtCapitalOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product ArtCapitalProduct @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("art_capital_order_line_items")
}

model ArtCapitalPayment {
  id          String        @id @default(uuid())
  orderId     String        @map("order_id")
  userId      String        @map("user_id")
  method      PaymentMethod
  amount      Decimal       @db.Decimal(12, 2)
  paymentDate DateTime      @map("payment_date")
  reference   String?       @db.VarChar(200)
  notes       String?       @db.Text
  createdAt   DateTime      @default(now()) @map("created_at")

  order ArtCapitalOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  ArtCapitalUser  @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([paymentDate])
  @@map("art_capital_payments")
}

model ArtCapitalTransaction {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  artistId         String    @map("artist_id")
  orderId          String    @map("order_id")
  userId           String    @map("user_id")
  amount           Decimal   @db.Decimal(12, 2)
  commissionRate   Decimal   @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal   @map("commission_amount") @db.Decimal(12, 2)
  status           String    @default("PENDING") @db.VarChar(20)
  paidAt           DateTime? @map("paid_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id])
  artist ArtCapitalArtist @relation(fields: [artistId], references: [id])
  order  ArtCapitalOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user   ArtCapitalUser   @relation(fields: [userId], references: [id])

  @@index([tenantId, status])
  @@index([artistId, paidAt])
  @@map("art_capital_transactions")
}

// ─── Gallery Models ───────────────────────────────────────────────────────────

model GalleryArtist {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  userId         String   @unique @map("user_id")
  name           String   @db.VarChar(200)
  bio            String?  @db.Text
  imageUrl       String?  @map("image_url") @db.VarChar(500)
  website        String?  @db.VarChar(500)
  socialMedia    Json     @default("{}")
  specialization Json     @default("[]")
  status         String   @default("ACTIVE") @db.VarChar(20)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  artworks    GalleryArtwork[]
  memberships GalleryMembership[]
  classes     GalleryClass[]

  @@index([tenantId, status])
  @@map("gallery_artists")
}

model GalleryCollection {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String   @db.VarChar(200)
  description String?  @db.Text
  image       String?  @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  artworks GalleryArtwork[]

  @@index([tenantId, isActive])
  @@map("gallery_collections")
}

model GalleryLocation {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String   @db.VarChar(200)
  address   String?  @db.VarChar(300)
  city      String?  @db.VarChar(100)
  phone     String?  @db.VarChar(30)
  whatsapp  String?  @db.VarChar(30)
  imageUrl  String?  @map("image_url") @db.VarChar(500)
  hours     Json     @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  artworks    GalleryArtwork[]
  classes     GalleryClass[]
  exhibitions GalleryExhibition[]

  @@index([tenantId, isActive])
  @@map("gallery_locations")
}

model GalleryArtwork {
  id                         String        @id @default(uuid())
  tenantId                   String        @map("tenant_id")
  artistId                   String        @map("artist_id")
  collectionId               String?       @map("collection_id")
  locationId                 String?       @map("location_id")
  title                      String        @db.VarChar(300)
  description                String?       @db.Text
  price                      Decimal       @db.Decimal(12, 2)
  quantity                   Int           @default(1)
  status                     ArtworkStatus @default(AVAILABLE)
  mediums                    Json          @default("[]")
  styles                     Json          @default("[]")
  widthCm                    Decimal?      @map("width_cm") @db.Decimal(10, 2)
  heightCm                   Decimal?      @map("height_cm") @db.Decimal(10, 2)
  depthCm                    Decimal?      @map("depth_cm") @db.Decimal(10, 2)
  mainImage                  String?       @map("main_image") @db.VarChar(500)
  galleryImages              Json          @default("[]")
  artistCommissionPercentage Decimal?      @map("artist_commission_percentage") @db.Decimal(5, 2)
  metadata                   Json          @default("{}")
  isActive                   Boolean       @default(true) @map("is_active")
  createdAt                  DateTime      @default(now()) @map("created_at")
  updatedAt                  DateTime      @updatedAt @map("updated_at")

  tenant         Tenant                     @relation(fields: [tenantId], references: [id])
  artist         GalleryArtist              @relation(fields: [artistId], references: [id])
  collection     GalleryCollection?         @relation(fields: [collectionId], references: [id])
  location       GalleryLocation?           @relation(fields: [locationId], references: [id])
  cartItems      GalleryCartItem[]
  orderLineItems GalleryOrderLineItem[]
  favorites      GalleryFavorite[]
  exhibitions    GalleryExhibitionArtwork[]

  @@index([tenantId, status])
  @@index([artistId])
  @@index([collectionId])
  @@map("gallery_artworks")
}

model GalleryMembership {
  id                   String   @id @default(uuid())
  tenantId             String   @map("tenant_id")
  artistId             String   @map("artist_id")
  name                 String   @db.VarChar(200)
  membershipType       String   @db.VarChar(50)
  price                Decimal  @db.Decimal(12, 2)
  description          String?  @db.Text
  commissionPercentage Decimal  @map("commission_percentage") @db.Decimal(5, 2)
  features             Json     @default("[]")
  startDate            DateTime @map("start_date")
  endDate              DateTime @map("end_date")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  artist GalleryArtist @relation(fields: [artistId], references: [id])

  @@unique([artistId, membershipType])
  @@index([tenantId, isActive])
  @@map("gallery_memberships")
}

model GalleryClass {
  id           String      @id @default(uuid())
  tenantId     String      @map("tenant_id")
  instructorId String      @map("instructor_id")
  locationId   String      @map("location_id")
  name         String      @db.VarChar(200)
  description  String?     @db.Text
  price        Decimal?    @db.Decimal(12, 2)
  schedule     Json        @default("{}")
  capacity     Int         @default(20)
  status       ClassStatus @default(ACTIVE)
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  tenant      Tenant                   @relation(fields: [tenantId], references: [id])
  instructor  GalleryArtist            @relation(fields: [instructorId], references: [id])
  location    GalleryLocation          @relation(fields: [locationId], references: [id])
  enrollments GalleryClassEnrollment[]
  cartItems   GalleryCartItem[]

  @@index([tenantId, status])
  @@index([instructorId])
  @@map("gallery_classes")
}

model GalleryClassEnrollment {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  userId       String   @map("user_id")
  classId      String   @map("class_id")
  enrolledDate DateTime @default(now()) @map("enrolled_date")
  status       String   @default("ACTIVE") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  class  GalleryClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([userId, classId])
  @@index([tenantId])
  @@map("gallery_class_enrollments")
}

model GalleryExhibition {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  locationId  String   @map("location_id")
  title       String   @db.VarChar(300)
  description String?  @db.Text
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  status      String   @default("PLANNING") @db.VarChar(20)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant                     @relation(fields: [tenantId], references: [id])
  location GalleryLocation            @relation(fields: [locationId], references: [id])
  artworks GalleryExhibitionArtwork[]

  @@index([tenantId, status])
  @@map("gallery_exhibitions")
}

model GalleryExhibitionArtwork {
  exhibitionId String
  artworkId    String
  displayOrder Int    @default(0) @map("display_order")

  exhibition GalleryExhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  artwork    GalleryArtwork    @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@id([exhibitionId, artworkId])
  @@map("gallery_exhibition_artworks")
}

model GalleryCart {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant            @relation(fields: [tenantId], references: [id])
  items  GalleryCartItem[]

  @@unique([tenantId, userId])
  @@map("gallery_carts")
}

model GalleryCartItem {
  id        String   @id @default(uuid())
  cartId    String   @map("cart_id")
  artworkId String?  @map("artwork_id")
  classId   String?  @map("class_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  cart         GalleryCart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  artwork      GalleryArtwork? @relation(fields: [artworkId], references: [id])
  galleryClass GalleryClass?   @relation(fields: [classId], references: [id])
  Tenant       Tenant?         @relation(fields: [tenantId], references: [id])
  tenantId     String?

  @@map("gallery_cart_items")
}

model GalleryOrder {
  id                     String             @id @default(uuid())
  tenantId               String             @map("tenant_id")
  userId                 String             @map("user_id")
  orderNumber            String             @unique @db.VarChar(50)
  status                 GalleryOrderStatus @default(PENDING)
  subtotal               Decimal            @db.Decimal(12, 2)
  discountAmount         Decimal            @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount              Decimal            @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalPrice             Decimal            @map("total_price") @db.Decimal(12, 2)
  paymentStatus          String             @default("PENDING") @db.VarChar(20)
  shippingAddress        Json               @default("{}")
  trackingNumber         String?            @map("tracking_number") @db.VarChar(100)
  stripePaymentIntentId  String?            @map("stripe_payment_intent_id") @db.VarChar(255)
  stripeSessionId        String?            @map("stripe_session_id") @db.VarChar(255)
  artistCommissionAmount Decimal?           @map("artist_commission_amount") @db.Decimal(12, 2)
  metadata               Json               @default("{}")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  tenant    Tenant                 @relation(fields: [tenantId], references: [id])
  lineItems GalleryOrderLineItem[]

  @@index([tenantId, createdAt])
  @@index([userId])
  @@index([status])
  @@map("gallery_orders")
}

model GalleryOrderLineItem {
  id                         String   @id @default(uuid())
  orderId                    String   @map("order_id")
  artworkId                  String   @map("artwork_id")
  quantity                   Int      @default(1)
  unitPrice                  Decimal  @map("unit_price") @db.Decimal(12, 2)
  artistCommissionPercentage Decimal? @map("artist_commission_percentage") @db.Decimal(5, 2)
  artistCommissionAmount     Decimal? @map("artist_commission_amount") @db.Decimal(12, 2)
  discountAmount             Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount                  Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  subtotal                   Decimal  @db.Decimal(12, 2)
  createdAt                  DateTime @default(now()) @map("created_at")

  order    GalleryOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  artwork  GalleryArtwork @relation(fields: [artworkId], references: [id])
  Tenant   Tenant?        @relation(fields: [tenantId], references: [id])
  tenantId String?

  @@index([orderId])
  @@map("gallery_order_line_items")
}

model GalleryFavorite {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  artworkId String   @map("artwork_id")
  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant         @relation(fields: [tenantId], references: [id])
  artwork GalleryArtwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@unique([userId, artworkId])
  @@index([tenantId, userId])
  @@map("gallery_favorites")
}

// ─── Purchase Order Module ───────────────────────────────────────────────────

model Supplier {
  id                  String         @id @default(uuid())
  tenantId            String         @map("tenant_id")
  code                String         @map("code") @db.VarChar(50)
  name                String         @db.VarChar(200)
  description         String?        @db.Text
  type                SupplierType
  status              SupplierStatus @default(ACTIVE)
  rfc                 String?        @db.VarChar(20)
  taxId               String?        @map("tax_id") @db.VarChar(50)
  fiscalRegime        String?        @map("fiscal_regime") @db.VarChar(100)
  legalName           String?        @map("legal_name") @db.VarChar(300)
  email               String?        @db.VarChar(200)
  phone               String?        @db.VarChar(30)
  whatsapp            String?        @db.VarChar(30)
  website             String?        @db.VarChar(300)
  addressStreet       String?        @map("address_street") @db.VarChar(300)
  addressCity         String?        @map("address_city") @db.VarChar(100)
  addressState        String?        @map("address_state") @db.VarChar(100)
  addressZip          String?        @map("address_zip") @db.VarChar(20)
  addressCountry      String         @default("MX") @map("address_country") @db.VarChar(100)
  defaultPaymentTerms String?        @map("default_payment_terms") @db.VarChar(100)
  averageDeliveryDays Int            @default(5) @map("average_delivery_days")
  currencyCode        String         @default("MXN") @map("currency_code") @db.VarChar(10)
  createdById         String         @map("created_by_id")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  createdBy      User                @relation(fields: [createdById], references: [id])
  contacts       SupplierContact[]
  priceLists     SupplierPriceList[]
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("suppliers")
}

model SupplierContact {
  id         String   @id @default(uuid())
  supplierId String   @map("supplier_id")
  name       String   @db.VarChar(150)
  role       String   @db.VarChar(100)
  email      String?  @db.VarChar(200)
  phone      String?  @db.VarChar(30)
  whatsapp   String?  @db.VarChar(30)
  isPrimary  Boolean  @default(false) @map("is_primary")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  supplier       Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([supplierId])
  @@map("supplier_contacts")
}

model SupplierPriceList {
  id                     String    @id @default(uuid())
  tenantId               String    @map("tenant_id")
  supplierId             String    @map("supplier_id")
  code                   String    @map("code") @db.VarChar(50)
  name                   String    @db.VarChar(200)
  description            String?   @db.Text
  validFrom              DateTime  @map("valid_from")
  validTo                DateTime? @map("valid_to")
  minOrderQty            Decimal?  @map("min_order_qty") @db.Decimal(10, 3)
  maxOrderQty            Decimal?  @map("max_order_qty") @db.Decimal(10, 3)
  volumeDiscountRules    Json      @default("[]") @map("volume_discount_rules")
  creditDays             Int       @default(30) @map("credit_days")
  currency               String    @default("MXN") @db.VarChar(10)
  profitMarginSuggestion Decimal?  @default(0) @map("profit_margin_suggestion") @db.Decimal(5, 2)
  isActive               Boolean   @default(true) @map("is_active")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  tenant         Tenant                  @relation(fields: [tenantId], references: [id])
  supplier       Supplier                @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items          SupplierPriceListItem[]
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, code])
  @@index([supplierId, isActive])
  @@index([validFrom, validTo])
  @@map("supplier_price_lists")
}

model SupplierPriceListItem {
  id                 String             @id @default(uuid())
  priceListId        String             @map("price_list_id")
  resourceId         String             @map("resource_id")
  supplierSku        String?            @map("supplier_sku") @db.VarChar(100)
  unitPrice          Decimal            @map("unit_price") @db.Decimal(12, 2)
  availabilityStatus AvailabilityStatus @default(AVAILABLE) @map("availability_status")
  estimatedAvailable Decimal?           @map("estimated_available") @db.Decimal(10, 3)
  deliveryTimeDays   Int                @default(5) @map("delivery_time_days")
  isActive           Boolean            @default(true) @map("is_active")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  priceList SupplierPriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  resource  Resource          @relation("SupplierPriceListItems", fields: [resourceId], references: [id])

  @@unique([priceListId, resourceId])
  @@index([resourceId])
  @@map("supplier_price_list_items")
}

model PurchaseOrder {
  id                   String              @id @default(uuid())
  tenantId             String              @map("tenant_id")
  supplierId           String              @map("supplier_id")
  priceListId          String?             @map("price_list_id")
  orderNumber          String              @unique @map("order_number") @db.VarChar(50)
  status               PurchaseOrderStatus @default(DRAFT)
  originOrderId        String?             @map("origin_order_id")
  requiredDeliveryDate DateTime            @map("required_delivery_date")
  deliveryLocation     String?             @map("delivery_location") @db.VarChar(300)
  contactId            String?             @map("contact_id")
  description          String?             @db.Text
  notes                String?             @db.Text
  subtotal             Decimal             @default(0) @db.Decimal(12, 2)
  taxRate              Decimal             @default(16) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount            Decimal             @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total                Decimal             @default(0) @db.Decimal(12, 2)
  currency             String              @default("MXN") @db.VarChar(10)
  createdById          String              @map("created_by_id")
  confirmedById        String?             @map("confirmed_by_id")
  confirmedAt          DateTime?           @map("confirmed_at")
  cancelledAt          DateTime?           @map("cancelled_at")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  tenant        Tenant                       @relation(fields: [tenantId], references: [id])
  supplier      Supplier                     @relation(fields: [supplierId], references: [id])
  priceList     SupplierPriceList?           @relation(fields: [priceListId], references: [id])
  originOrder   Order?                       @relation(fields: [originOrderId], references: [id])
  contact       SupplierContact?             @relation(fields: [contactId], references: [id])
  createdBy     User                         @relation("POCreatedBy", fields: [createdById], references: [id])
  confirmedBy   User?                        @relation("POConfirmedBy", fields: [confirmedById], references: [id])
  lineItems     PurchaseOrderLineItem[]
  documents     PurchaseOrderDocument[]
  statusHistory PurchaseOrderStatusHistory[]

  @@index([tenantId, status])
  @@index([supplierId])
  @@index([orderNumber])
  @@map("purchase_orders")
}

model PurchaseOrderLineItem {
  id               String   @id @default(uuid())
  poId             String   @map("po_id")
  resourceId       String   @map("resource_id")
  description      String   @db.VarChar(500)
  supplierSku      String?  @map("supplier_sku") @db.VarChar(100)
  quantity         Decimal  @db.Decimal(10, 3)
  unitPrice        Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal        Decimal  @map("line_total") @db.Decimal(12, 2)
  deliveryTimeDays Int      @default(5) @map("delivery_time_days")
  notes            String?  @db.Text
  receivedQty      Decimal  @default(0) @map("received_qty") @db.Decimal(10, 3)
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  resource      Resource      @relation("PurchaseOrderLineItems", fields: [resourceId], references: [id])

  @@index([poId])
  @@map("purchase_order_line_items")
}

model PurchaseOrderStatusHistory {
  id          String               @id @default(uuid())
  poId        String               @map("po_id")
  fromStatus  PurchaseOrderStatus? @map("from_status")
  toStatus    PurchaseOrderStatus  @map("to_status")
  changedById String               @map("changed_by_id")
  notes       String?              @db.Text
  createdAt   DateTime             @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  changedBy     User          @relation(fields: [changedById], references: [id])

  @@index([poId])
  @@map("purchase_order_status_history")
}

model PurchaseOrderDocument {
  id           String   @id @default(uuid())
  poId         String   @map("po_id")
  documentType String   @map("document_type") @db.VarChar(100)
  fileName     String   @map("file_name") @db.VarChar(300)
  blobKey      String   @map("blob_key") @db.VarChar(500)
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  uploadedBy    User          @relation(fields: [uploadedById], references: [id])

  @@index([poId])
  @@map("purchase_order_documents")
}
