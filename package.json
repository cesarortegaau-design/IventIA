{
  "name": "iventia",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "turbo run db:migrate --filter=@iventia/prisma",
    "db:seed": "turbo run db:seed --filter=@iventia/prisma",
    "db:studio": "turbo run db:studio --filter=@iventia/prisma",
    "postinstall": "prisma generate --schema=./packages/prisma/schema.prisma"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
