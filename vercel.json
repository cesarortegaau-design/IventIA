{
  "buildCommand": "pnpm install && pnpm --filter @iventia/community build",
  "outputDirectory": "apps/community/dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.exposaantafe.com.mx/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
